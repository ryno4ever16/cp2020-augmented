{{!--
  Environmental radiation form (R3b — Deep Space p.21/23). Cosmic rays (1D6 millirad/hr) or a solar flare
  (Strength × D6 rads/hr) over N hours, applied to the selected tokens. Fields read by
  openEnvironmentalDialog() in module/radiation/radiation-tools.js via the .cp-rad-* classes. The Strength
  field is only used in flare mode. i18n via CPLocal; triple-stash the target line (it carries <b>).
--}}
<form class="cp-rad-dialog">
  {{#if multiple}}
  <p class="cp-rad-targets">{{{CPLocal "RadTargetsMulti" names=names}}}</p>
  {{else}}
  <p class="cp-rad-targets">{{{CPLocal "RadTargetsOne" names=names}}}</p>
  {{/if}}
  <div class="form-group">
    <label>{{CPLocal "RadFieldMode"}}</label>
    <select class="cp-rad-mode">
      <option value="cosmic">{{CPLocal "RadModeCosmic"}}</option>
      <option value="flare">{{CPLocal "RadModeFlare"}}</option>
    </select>
  </div>
  <div class="form-group">
    <label>{{CPLocal "RadFieldHours"}}</label>
    <input type="number" class="cp-rad-hours" value="1" min="1" step="1" autofocus>
  </div>
  <div class="form-group">
    <label title="{{CPLocal 'RadFieldStrengthHint'}}">{{CPLocal "RadFieldStrength"}}</label>
    <input type="number" class="cp-rad-strength" value="1" min="1" step="1">
  </div>
</form>
