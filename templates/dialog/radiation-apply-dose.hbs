{{!--
  Apply-dose form (R3b — Deep Space radiation). Fields are read by openApplyDoseDialog() in
  module/radiation/radiation-tools.js via the .cp-rad-* classes on confirm. i18n via CPLocal; triple-stash
  the target line (it carries <b>). No HTML/CSS built in JS.
--}}
<div class="cp-rad-dialog">
  {{#if multiple}}
  <p class="cp-rad-targets">{{{CPLocal "RadTargetsMulti" names=names}}}</p>
  {{else}}
  <p class="cp-rad-targets">{{{CPLocal "RadTargetsOne" names=names}}}</p>
  {{/if}}
  <div class="form-group">
    <label>{{CPLocal "RadFieldRads"}}</label>
    <input type="number" class="cp-rad-rads" value="0" min="0" step="1" autofocus>
  </div>
  <div class="form-group">
    <label>{{CPLocal "RadFieldSource"}}</label>
    <input type="text" class="cp-rad-source" placeholder="{{CPLocal 'RadFieldSourcePlaceholder'}}">
  </div>
  <div class="form-group">
    <label title="{{CPLocal 'RadFieldPerTurnHint'}}">{{CPLocal "RadFieldPerTurn"}}</label>
    <input type="checkbox" class="cp-rad-perturn" checked>
  </div>
</div>
