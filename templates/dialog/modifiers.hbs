{{!-- Dialog content for when a ranged weapon is fired --}}
{{!-- By this point, fire mode and range should be selected, and possibly target --}}
{{!-- V2: NOT a <form> — the outer <form> is provided by the dialog's tag:"form". A nested form here
     submits natively (GET → game?firemode=…) and bricks the app; the fire <button type="submit">
     instead routes to the V2 form.handler (_formHandler). --}}
<div class="cyberpunk weapon-modifiers">
    {{#each modifierGroups as |group|}}
        <div class="field-list">
            {{#each group}}
                {{!-- Have to set the context to be values for now cos fields just look things up in their context, and values is where the actual values are --}}
                {{!-- This COULD be neater if we make fields look in a specific place (eg values) --}}
                {{#with ../../defaultValues}}
                    {{>(template ../fieldPath) label=../localKey edit=../dataPath choices=../choices noTranslateChoices=../noTranslateChoices allowBlank=../allowBlank readOnly=../readOnly max=../max min=../min}}
                {{/with}}
            {{/each}}
        </div>
    {{/each}}

    {{#if isRanged}}
    <div class="field-list">
      <div class="field">
        <label>{{CPLocal "ShotsLeft"}}</label>
        <span class="flex-pad"></span>
        <input type="number"
               class="number nogrow nowidth"
               value="{{shotsLeft}}"
               readonly />
      </div>
      <div class="field full-width cp-ammo-tracking-toggle" title="{{CPLocal 'AmmoTrackingHint'}}">
        <label class="cp-ammo-tracking-label">{{#if ammoTracking}}{{CPLocal "AmmoTracking"}}{{else}}{{CPLocal "FreeFire"}}{{/if}}</label>
        <input type="checkbox" class="cp-ammo-tracking" {{#if ammoTracking}}checked{{/if}}>
      </div>
    </div>
    {{/if}}

    {{#if (hasElements targetTokens)}}
        <h2>{{CPLocal "Targets"}}</h2>
        <div class="fieldrow" style="margin-bottom: 5px; width: auto">
        {{#each targetTokens}}
            <div class="field">
                <span style="width: 100%">{{this.name}}</span>
            </div>
        {{/each}}
        </div>
    {{/if}}

    {{#if showAdvDis}}
    <div class="field-list">
        <div class="field full-width">
            <label>{{CPLocal "Advantage"}}</label>
            <input type="checkbox" name="advantage" class="adv-dis adv" {{#if advantage}}checked{{/if}}>
        </div>

        <div class="field full-width">
            <label>{{CPLocal "Disadvantage"}}</label>
            <input type="checkbox" name="disadvantage" class="adv-dis dis" {{#if disadvantage}}checked{{/if}}>
        </div>

        {{#if isGM}}
        <div class="field full-width">
            <label>{{CPLocal "HiddenAdvantage"}}</label>
            <input type="checkbox" name="hiddenAdvantage" class="adv-hidden" {{#if hiddenAdvantage}}checked{{/if}}>
        </div>
        {{/if}}
    </div>
    {{/if}}

    <div class="flexrow" style="justify-content: flex-end; gap: 8px;">
    {{#if isRanged}}
        <button type="button" class="reload">{{CPLocal "Reload"}}</button>
        <button type="button" class="unload">{{CPLocal "Unload"}}</button>
    {{/if}}
    <button type="submit" name="submit" class="fire" value="1" autofocus>
        {{CPLocal "OK"}}
    </button>
    </div>
</div>