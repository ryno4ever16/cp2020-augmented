{{!--
  modules/cp2020-augmented/templates/dialog/damage-dialog.hbs

  Damage sequence displayed:
    Roll (raw) − SP = after-SP damage   ← editable
    Then on Apply: − BTM = HP written to character (min 1 if SP penetrated)

  BTM is NOT pre-applied in the preview. It is the character's personal
  toughness and is only subtracted at the moment damage is actually received.
--}}
{{!-- V2: NOT a <form> — the outer <form> is provided by the dialog's tag:"form". The Apply/Cancel
     buttons are data-action handlers; a nested form here lets Enter submit natively (GET) and brick
     the app. --}}
<div class="cyberpunk flexcol damage-dialog">

  {{!-- Header --}}
  <div class="field-list one-col">
    <div class="field">
      <label>{{CPLocal "Weapon"}}</label>
      <span class="flex-pad">{{weaponName}}</span>
    </div>
    <div class="field">
      <label>{{CPLocal "Target"}}</label>
      <span class="flex-pad">{{targetName}}</span>
    </div>
    {{#if ap}}
    <div class="field inactive">
      <span>{{CPLocal "DamageDlgApRound"}}</span>
    </div>
    {{/if}}
  </div>

  <hr>

  {{!-- Per-hit table --}}
  <div class="damage-hit-list field-list one-col">
    <div class="field inactive" style="font-size:0.8em; gap:4px; padding-bottom:2px;">
      <span style="min-width:60px;">{{CPLocal "Location"}}</span>
      <span class="flex-pad"></span>
      <span style="min-width:36px; text-align:right;" title="{{CPLocal 'DamageDlgRollTip'}}">{{CPLocal "DamageDlgRoll"}}</span>
      <span style="width:14px; text-align:center;">−</span>
      <span style="min-width:36px; text-align:right;" title="{{CPLocal 'DamageDlgSpTip'}}">{{CPLocal "SP"}}</span>
      <span style="width:14px; text-align:center;">=</span>
      <span style="min-width:52px; text-align:right;" title="{{CPLocal 'DamageDlgAfterSpHeaderTip'}}">{{CPLocal "DamageDlgAfterSp"}}</span>
    </div>

    {{#each resolvedHits as |hit i|}}
    <div class="damage-hit field" style="gap:4px;">
      <span style="min-width:60px;">{{hit.location}}</span>
      <span class="flex-pad"></span>
      <span class="inactive" style="min-width:36px; text-align:right;">{{hit.rawDamage}}</span>
      <span class="inactive" style="width:14px; text-align:center;">−</span>
      <span class="inactive" style="min-width:36px; text-align:right;"
        title="{{#if hit.penetrates}}{{CPLocal 'DamageDlgPenetrated'}}{{else}}{{CPLocal 'DamageDlgStopped'}}{{/if}}">{{hit.spUsed}}</span>
      <span class="inactive" style="width:14px; text-align:center;">=</span>
      <input
        type="number"
        class="after-sp-override number nogrow"
        data-hit-index="{{@index}}"
        value="{{hit.afterSP}}"
        min="0"
        style="width:52px; text-align:right;"
        title="{{CPLocal 'DamageDlgAfterSpTip' btm=../../btm}}">
      {{#unless hit.penetrates}}<span class="inactive" style="font-size:0.75em;" title="{{CPLocal 'DamageDlgStopped'}}">✗</span>{{/unless}}
      {{#if hit.overridden}}<span class="inactive" style="font-size:0.75em; color:var(--color-text-hyperlink);" title="{{CPLocal 'DamageDlgOverridden'}}">✎</span>{{/if}}
    </div>
    {{/each}}
  </div>

  {{!-- BTM line + total --}}
  <div class="field inactive" style="margin-top:4px; font-size:0.85em;">
    <span>{{CPLocal "DamageDlgBtmLine" btm=btm}}</span>
  </div>
  <div class="field" style="margin-top:2px; font-weight:bold;">
    <label>{{CPLocal "DamageDlgTotalHp"}}</label>
    <span class="flex-pad"></span>
    <strong class="damage-total-value">{{totalNet}}</strong>
  </div>

  <hr>

  {{!-- Options --}}
  <div class="field-list one-col damage-options">
    <div class="field">
      <label title="{{CPLocal 'DamageDlgCoverSpTip'}}">{{CPLocal "DamageDlgCoverSp"}}</label>
      <span class="flex-pad"></span>
      <input
        type="number"
        name="coverSP"
        class="number nogrow"
        value="{{coverSP}}"
        min="0"
        style="width:52px; text-align:right;"
        title="{{CPLocal 'DamageDlgCoverSpExamples'}}">
    </div>

    <div class="field">
      <label>{{CPLocal "DamageDlgArmorMode"}}</label>
      <span class="flex-pad"></span>
      <select name="armorMode" class="nogrow">
        <option value="full"   {{#if (equals armorMode "full")}}selected{{/if}}>{{CPLocal "DamageDlgArmorFull"}}</option>
        <option value="simple" {{#if (equals armorMode "simple")}}selected{{/if}}>{{CPLocal "DamageDlgArmorSimple"}}</option>
        <option value="none"   {{#if (equals armorMode "none")}}selected{{/if}}>{{CPLocal "DamageDlgArmorNone"}}</option>
      </select>
    </div>

    <div class="field">
      <label>{{CPLocal "DamageDlgType"}}</label>
      <span class="flex-pad"></span>
      <select name="damageType" class="nogrow">
        <option value=""          {{#if (equals damageType "")}}selected{{/if}}>{{CPLocal "DamageDlgTypeNormal"}}</option>
        <option value="fire"      {{#if (equals damageType "fire")}}selected{{/if}}>{{CPLocal "DamageDlgTypeFire"}}</option>
        <option value="heat"      {{#if (equals damageType "heat")}}selected{{/if}}>{{CPLocal "DamageDlgTypeHeat"}}</option>
        {{!-- "Radiation" removed as a per-hit SP damage type: radiation is now the Deep Space dose subsystem
              (module/radiation/), reduced by an RSP suit rather than by armor SP. Fire/heat stay (armor DOES
              stop + ablate under thermal). --}}
      </select>
    </div>

    <div class="field">
      <label>{{CPLocal "DamageDlgAblate"}}</label>
      <span class="flex-pad"></span>
      <input type="checkbox" name="ablate" {{#if ablate}}checked{{/if}}>
    </div>
  </div>

  <div class="flexrow dialog-buttons" style="margin-top:8px; gap:4px;">
    <button type="button" data-action="applyDamage"  class="action">{{CPLocal "DamageDlgApplyBtn"}}</button>
    <button type="button" data-action="cancelDialog">{{CPLocal "Cancel"}}</button>
  </div>

</div>
