{{!--
  In-skill martial-art editor (module injection, vanilla only). Mark a skill as a martial art and set
  its per-action bonuses. Stored under flags.cp2020-augmented.* — his vanilla skill DataModel has no
  isMartialArt / martialBonuses fields (the fork keeps them in system.*). The module fork-skips when
  the system already renders [name="system.isMartialArt"]. Labels: MartialIsArtLabel/MartialBonusesLabel
  are module-owned (his vanilla lacks CYBERPUNK.IsMartialArt); the per-action names are shared keys.
--}}
<div class="field-list cp2020ae-martial-editor">
  <div class="field cp2020ae-ma-isma-field">
    <label>{{CPLocal "MartialIsArtLabel"}}</label>
    <span class="flex-pad"></span>
    <input type="checkbox" class="cp2020ae-ma-isma" {{#if isMA}}checked{{/if}}>
  </div>

  <div class="cp2020ae-ma-bonus-grid"{{#unless isMA}} style="display:none;"{{/unless}}>
    <div class="cp2020ae-ma-bonus-header">{{CPLocal "MartialBonusesLabel"}}</div>
    {{#each actions as |a|}}
      <div class="field cp2020ae-ma-bonus-field">
        <label>{{CPLocal a.action}}</label>
        <span class="flex-pad"></span>
        <input type="number" class="cp2020ae-ma-bonus number" data-action="{{a.action}}" value="{{a.value}}">
      </div>
    {{/each}}
  </div>
</div>
