
{{!-- Use as 
    {{#> systems/cyberpunk2020/templates/item/item-sheet.hbs}}
        settings tab contents
    {{/systems/cyberpunk2020/templates/item/item-sheet.hbs}}
 --}}
{{!-- V2 single-root part: <form> is now provided by the sheet's tag:"form"; this div is the part's
      single root element. flex:1 fills the V2 form; inner content keeps its original block flow. --}}
<div class="cyberpunk {{cssClass}} cp-item-sheet-root" style="flex:1;min-height:0;">
    <header class="flexrow nowrap">
        <div class="flexcol item-info">
            <span class="infoline">
                <h1 class="title">
                    <input class="field-value fillwidth" name="name" type="search" value="{{item.name}}" placeholder="{{CPLocal 'ItemName'}}" autocomplete="off" data-lpignore="true" data-1p-ignore data-bwignore/>
                </h1>
                <span class="summary inactive">{{> (augVarTemplate "item/parts/[VAR]/summary.hbs" item.type)}}</span>
            </span>
            <textarea class="flavor" name="system.flavor" placeholder="{{CPLocal 'Flavor'}}">{{system.flavor}}</textarea>
        </div>
        <img class="item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    </header>

    {{!-- Sheet Tab Navigation --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="settings">{{CPLocal 'Settings'}}</a>
        <a class="item" data-tab="notes">{{CPLocal 'Notes'}}</a>
    </nav>

    {{!-- Sheet Body --}}
    <section class="sheet-body">
        
        {{!-- Notes Tab (his prose-mirror view/edit toggle; driven by _cpActivateNotesEditor + notesEditing) --}}
        <div class="tab notes flexcol" data-group="primary" data-tab="notes">
            <div class="cp-notes-editor" data-editor-target="system.notes">
                <div class="cp-notes-canvas {{#if notesEditing}}is-editing{{else}}is-viewing{{/if}}">
                    {{#if editable}}
                        {{#unless notesEditing}}
                            <button
                                type="button"
                                class="cp-notes-edit"
                                data-action="notes-edit"
                                title="{{localize 'CYBERPUNK.ItemNotesEdit'}}"
                                aria-label="{{localize 'CYBERPUNK.ItemNotesEdit'}}"
                            >
                                <i class="fas fa-edit"></i>
                            </button>
                        {{/unless}}
                    {{/if}}

                    {{#if notesEditing}}
                        <prose-mirror
                            class="cp-notes-prosemirror"
                            name="system.notes"
                            value="{{system.notes}}"
                        >{{{system.notes}}}</prose-mirror>
                    {{else}}
                        <div class="cp-notes-view">
                            {{{system.notes}}}
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>

        {{!-- Attributes Tab --}}
        <div class="tab" data-group="primary" data-tab="settings">
            
            {{#unless (equals item.type "misc")}}
            {{> (augVarTemplate "item/parts/[VAR]/settings.hbs" item.type)}}
            {{/unless}}
            {{!-- Not all items have common settings --}}
            {{!-- May be worth instead other settings things just including the template on their own --}}
            {{#if (hasProperty item.system "equipped")}}
            {{> (augVarTemplate "item/parts/misc/settings.hbs" item.type)}}
            {{/if}}
        </div>
    </section>
</div>