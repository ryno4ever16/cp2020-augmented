{{!-- Maximum Metal vehicle/ACPA weapon. Fields from the MM stat block (p.4/17/19/20/22). --}}

{{!-- Classification --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.WClassTip'}}">
        <label>{{CPLocal "Vehicle.WClass"}}</label>
        <select name="system.weaponClass">
            <option value="directFire" {{#if (equals system.weaponClass "directFire")}}selected{{/if}}>{{CPLocal "Vehicle.WClassDirectFire"}}</option>
            <option value="burst" {{#if (equals system.weaponClass "burst")}}selected{{/if}}>{{CPLocal "Vehicle.WClassBurst"}}</option>
            <option value="rocket" {{#if (equals system.weaponClass "rocket")}}selected{{/if}}>{{CPLocal "Vehicle.WClassRocket"}}</option>
            <option value="missile" {{#if (equals system.weaponClass "missile")}}selected{{/if}}>{{CPLocal "Vehicle.WClassMissile"}}</option>
            <option value="artillery" {{#if (equals system.weaponClass "artillery")}}selected{{/if}}>{{CPLocal "Vehicle.WClassArtillery"}}</option>
            <option value="bomb" {{#if (equals system.weaponClass "bomb")}}selected{{/if}}>{{CPLocal "Vehicle.Bomb"}}</option>
            <option value="cone" {{#if (equals system.weaponClass "cone")}}selected{{/if}}>{{CPLocal "Vehicle.WClassCone"}}</option>
            <option value="melee" {{#if (equals system.weaponClass "melee")}}selected{{/if}}>{{CPLocal "Vehicle.WClassMelee"}}</option>
            <option value="special" {{#if (equals system.weaponClass "special")}}selected{{/if}}>{{CPLocal "Special"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.WMountTip'}}">
        <label>{{CPLocal "Vehicle.WMount"}}</label>
        <select name="system.mountType">
            <option value="turret" {{#if (equals system.mountType "turret")}}selected{{/if}}>{{CPLocal "Vehicle.MountTurret"}}</option>
            <option value="fixed" {{#if (equals system.mountType "fixed")}}selected{{/if}}>{{CPLocal "Vehicle.MountFixed"}}</option>
            <option value="articulated" {{#if (equals system.mountType "articulated")}}selected{{/if}}>{{CPLocal "Vehicle.MountArticulated"}}</option>
            <option value="open" {{#if (equals system.mountType "open")}}selected{{/if}}>{{CPLocal "Vehicle.MountOpen"}}</option>
            <option value="pintle" {{#if (equals system.mountType "pintle")}}selected{{/if}}>{{CPLocal "Vehicle.MountPintle"}}</option>
            <option value="pod" {{#if (equals system.mountType "pod")}}selected{{/if}}>{{CPLocal "Vehicle.MountPod"}}</option>
            <option value="juryRigged" {{#if (equals system.mountType "juryRigged")}}selected{{/if}}>{{CPLocal "Vehicle.MountJuryRigged"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.WArcTip'}}">
        <label>{{CPLocal "Vehicle.WArc"}}</label>
        <select name="system.arc">
            <option value="turret" {{#if (equals system.arc "turret")}}selected{{/if}}>{{CPLocal "Vehicle.ArcTurret"}}</option>
            <option value="front" {{#if (equals system.arc "front")}}selected{{/if}}>{{CPLocal "Vehicle.ArcFront"}}</option>
            <option value="side" {{#if (equals system.arc "side")}}selected{{/if}}>{{CPLocal "Vehicle.ArcSide"}}</option>
            <option value="rear" {{#if (equals system.arc "rear")}}selected{{/if}}>{{CPLocal "Vehicle.ArcRear"}}</option>
        </select>
    </div>
</div>

{{!-- To-hit + damage scale --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.WATip'}}">
        <label>{{CPLocal "Vehicle.WA"}}</label><input type="number" name="system.wa" value="{{system.wa}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.PenetrationTip'}}">
        <label>{{CPLocal "Penetration"}}</label><input type="number" name="system.penetration" value="{{system.penetration}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.DamageDiceTip'}}">
        <label>{{CPLocal "Vehicle.DamageDice"}}</label><input type="text" name="system.damage" value="{{system.damage}}"/>
    </div>
</div>

{{!-- Damage flags --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.FlagAPTip'}}">
        <label>{{CPLocal "Vehicle.FlagAP"}}</label><input type="checkbox" name="system.ap" {{#if system.ap}}checked{{/if}}/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.FlagHEATTip'}}">
        <label>{{CPLocal "Vehicle.FlagHEAT"}}</label><input type="checkbox" name="system.heat" {{#if system.heat}}checked{{/if}}/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.FlagHiExTip'}}">
        <label>{{CPLocal "Vehicle.FlagHiEx"}}</label><input type="checkbox" name="system.hiEx" {{#if system.hiEx}}checked{{/if}}/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.HiDensityAPTip'}}">
        <label>{{CPLocal "Vehicle.HiDensityAP"}}</label><input type="checkbox" name="system.highDensityAP" {{#if system.highDensityAP}}checked{{/if}}/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.BurstMTip'}}">
        <label>{{CPLocal "Vehicle.BurstM"}}</label><input type="number" name="system.burst" value="{{system.burst}}"/>
    </div>
</div>

{{!-- Rate / ammo / range --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.ROFTip'}}">
        <label>{{CPLocal "Vehicle.ROF"}}</label><input type="number" name="system.rof" value="{{system.rof}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ROFAltTip'}}">
        <label>{{CPLocal "Vehicle.ROFAlt"}}</label><input type="number" name="system.rofAlt" value="{{system.rofAlt}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ShotsTip'}}">
        <label>{{CPLocal "Shots"}}</label><input type="number" name="system.shots" value="{{system.shots}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.RangeMTip'}}">
        <label>{{CPLocal "Vehicle.RangeM"}}</label><input type="number" name="system.range" value="{{system.range}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.MinRangeTip'}}">
        <label>{{CPLocal "Vehicle.MinRange"}}</label><input type="number" name="system.minRange" value="{{system.minRange}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ReliabilityTip'}}">
        <label>{{CPLocal "Reliability"}}</label>
        <select name="system.reliability">
            <option value="ST" {{#if (equals system.reliability "ST")}}selected{{/if}}>ST</option>
            <option value="VR" {{#if (equals system.reliability "VR")}}selected{{/if}}>VR</option>
            <option value="UR" {{#if (equals system.reliability "UR")}}selected{{/if}}>UR</option>
        </select>
    </div>
</div>

{{!-- Guidance (missiles) --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.GuidanceTip'}}">
        <label>{{CPLocal "Vehicle.Guidance"}}</label>
        <select name="system.guidance">
            <option value="none" {{#if (equals system.guidance "none")}}selected{{/if}}>{{CPLocal "Vehicle.GuidanceNone"}}</option>
            <option value="semiActive" {{#if (equals system.guidance "semiActive")}}selected{{/if}}>{{CPLocal "Vehicle.GuidanceSemiActive"}}</option>
            <option value="active" {{#if (equals system.guidance "active")}}selected{{/if}}>{{CPLocal "Vehicle.GuidanceActive"}}</option>
            <option value="paint" {{#if (equals system.guidance "paint")}}selected{{/if}}>{{CPLocal "Vehicle.GuidancePaint"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.GuideSkillTip'}}">
        <label>{{CPLocal "Vehicle.GuideSkill"}}</label><input type="number" name="system.guidanceSkill" value="{{system.guidanceSkill}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.HomingTip'}}">
        <label>{{CPLocal "Vehicle.Homing"}}</label>
        <select name="system.homingMethod">
            <option value="radar" {{#if (equals system.homingMethod "radar")}}selected{{/if}}>{{CPLocal "Vehicle.HomingRadar"}}</option>
            <option value="thermal" {{#if (equals system.homingMethod "thermal")}}selected{{/if}}>{{CPLocal "Vehicle.HomingThermal"}}</option>
            <option value="optical" {{#if (equals system.homingMethod "optical")}}selected{{/if}}>{{CPLocal "Vehicle.HomingOptical"}}</option>
            <option value="laser" {{#if (equals system.homingMethod "laser")}}selected{{/if}}>{{CPLocal "Laser"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ConeAngleTip'}}">
        <label>{{CPLocal "Vehicle.ConeAngle"}}</label><input type="number" name="system.coneAngle" value="{{system.coneAngle}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ProjectilesTip'}}">
        <label>{{CPLocal "Vehicle.Projectiles"}}</label><input type="number" name="system.projectiles" value="{{system.projectiles}}"/>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.ScatterDiceTip'}}">
        <label>{{CPLocal "Vehicle.ScatterDice"}}</label><input type="number" name="system.scatterDice" value="{{system.scatterDice}}"/>
    </div>
</div>

{{!-- Construction (Equipped / Cost / Weight / Source come from the common panel below) --}}
<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.WSpacesTip'}}">
        <label>{{CPLocal "Spaces"}}</label><input type="number" name="system.space" value="{{system.space}}"/>
    </div>
</div>

{{!-- Shell / warhead variants — selectable shells offered at fire time (artillery / bombs / HE). --}}
<h3 class="cyber-section-header" style="margin-top:8px;">{{CPLocal "Vehicle.ShellVariantsHeader"}}</h3>
<p style="opacity:0.6; font-size:0.78em; margin:0 0 4px;">{{CPLocal "Vehicle.ShellVariantsHint"}}</p>
<div class="cp-shellvariants">
    {{#each system.shellVariants as |v i|}}
    <div class="cp-shellvar" data-index="{{i}}" style="display:flex; gap:6px; align-items:center; flex-wrap:wrap; margin-bottom:3px;">
        <input type="text" class="cp-sv" data-field="name" value="{{v.name}}" placeholder="{{CPLocal 'Vehicle.ShellNamePlaceholder'}}" style="flex:1 1 120px;"/>
        <label style="font-size:0.8em;">{{CPLocal "Vehicle.ShellPenLabel"}} <input type="number" class="cp-sv" data-field="pen" value="{{v.pen}}" style="width:44px;"/></label>
        <label style="font-size:0.8em;">{{CPLocal "Vehicle.ShellBurstLabel"}} <input type="number" class="cp-sv" data-field="burst" value="{{v.burst}}" style="width:44px;"/></label>
        <select class="cp-sv" data-field="warhead" style="font-size:0.8em;">
            <option value="" {{#if (equals v.warhead "")}}selected{{/if}}>{{CPLocal "Vehicle.ShellWarheadHE"}}</option>
            <option value="heat" {{#if (equals v.warhead "heat")}}selected{{/if}}>{{CPLocal "Vehicle.ShellWarheadHEAT"}}</option>
            <option value="wp" {{#if (equals v.warhead "wp")}}selected{{/if}}>{{CPLocal "Vehicle.ShellWarheadWP"}}</option>
            <option value="cluster" {{#if (equals v.warhead "cluster")}}selected{{/if}}>{{CPLocal "Vehicle.ShellWarheadCluster"}}</option>
            <option value="chemical" {{#if (equals v.warhead "chemical")}}selected{{/if}}>{{CPLocal "Vehicle.ShellWarheadChemical"}}</option>
        </select>
        <label style="font-size:0.8em;" title="{{CPLocal 'Vehicle.ShellAPTip'}}">{{CPLocal "AP"}} <input type="checkbox" class="cp-sv" data-field="ap" {{#if v.ap}}checked{{/if}}/></label>
        <button type="button" class="cp-sv-remove" data-index="{{i}}" title="{{CPLocal 'Vehicle.ShellRemoveTip'}}" style="padding:0 6px;">✕</button>
    </div>
    {{/each}}
    <button type="button" class="cp-sv-add" style="margin-top:2px;">{{CPLocal "Vehicle.ShellAddBtn"}}</button>
</div>
