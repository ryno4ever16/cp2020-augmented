{{!-- cp-vehicle-item-fields: a display:contents wrapper used ONLY to scope the label-width
      fix (css) to the vehicle item sheet, without changing the field-list layout. The bare
      `vehicle` item sheet has no `.vehicle` class, so it never gets the actor sheet's label
      rules and its long labels (Speed/Fuel/Passengers/Maneuverability/Efficiency) otherwise
      collapse to ~0 width and overprint their inputs. --}}
<div class="cp-vehicle-item-fields">
{{!-- Identity / capacity (audit-walk schema upgrade — VEHICLE-SPEC.md §4). vehicleType is a SOFT
      enum: free text + a suggestions datalist, so the books' own class vocabulary survives. The
      datalist id is per-item to avoid the fixed-id singleton clash across two open sheets. --}}
<div class="field-list">
    <div class="field">
        <label for="system.vehicleType">{{CPLocal "VehicleClass"}}</label>
        <span class="flexrow flex-pad">
            <input type="text" name="system.vehicleType" value="{{system.vehicleType}}" list="cp-vehicle-types-{{@root.item._id}}">
        </span>
        <datalist id="cp-vehicle-types-{{@root.item._id}}">
            {{#each @root.veh.vehicleTypeSuggestions}}<option value="{{this}}"></option>{{/each}}
        </datalist>
    </div>
    <div class="field">
        <label for="system.crew">{{CPLocal "Crew"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.crew" value="{{system.crew}}">
        </span>
    </div>
    <div class="field">
        <label for="system.body" title="{{CPLocal "BodyRatingFull"}}">{{CPLocal "Body"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.body" value="{{system.body}}">
        </span>
    </div>
</div>
{{!-- Structural Damage Points (SDP is a terrible name) --}}
<div class="field-list">
    {{#with system.sdp}}
    <div class="flexcol fillwidth span-two-cells"  title="{{CPLocal "SDPFull"}}">
        <div class="meter-gauge fillwidth">
            <span style="width: calc(100% * ({{value}}/{{max}}));" class="
            {{#if (compare value "<=" (math max "/" 2))}}
            danger
            {{/if}}"></span>
        </div>

        <div class="field">
            <label class="larger" for="system.sdp.value" title="{{CPLocal "SDPFull"}}">{{CPLocal "SDP"}}</label>
            <span class="flexrow flex-pad">
                <input type="number" name="system.sdp.value" value="{{value}}"> 
                <span class="nogrow">/</span>
                <input type="number" name="system.sdp.max" value="{{max}}">
            </span>
        </div>
    </div>{{!-- /.flexcol.span-two-cells — was left unclosed, which swallowed every later field-list --}}
    {{/with}}

    <div class="field">
        <label for="system.sp" title="{{CPLocal "SPFull"}}">{{CPLocal "SP"}}</label>
        <span class="flex-pad"></span>
        <input type="number" class="number nogrow" name="system.sp" value="{{system.sp}}">
    </div>
</div>
<div class="field-list">
    {{!-- There's a reason I don't use meter here - it's evil to style, and IE doesn't support it. If anyone playing this is using IE, they're already in the dystopia --}}
    {{#with system.speed}}
    <div class="flexcol fillwidth span-two-cells">
        <div class="meter-gauge fillwidth">
            <span style="width: calc(100% * ({{value}}/{{max}}));" class="
            {{#if (compare value ">" maneuver)}}
            danger
            {{/if}}"></span>
        </div>
    </div>
    <div class="field">
        {{!-- Make larger to indicate a kind of heading almost --}}
        <label class="larger" for="system.speed.value">{{CPLocal "Speed"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.speed.value" value="{{value}}"> 
            <span class="nogrow">/</span>
            <input type="number" name="system.speed.max" value="{{max}}">
            {{#if @root.editable}}
            <select name="system.speed.unit" class="nogrow cp-unit-select">
                <option value="mph" {{#if (equals unit "mph")}}selected{{/if}}>mph</option>
                <option value="kph" {{#if (equals unit "kph")}}selected{{/if}}>kph</option>
            </select>
            {{else}}
            <span class="nogrow cp-unit-static">{{@root.veh.speedUnit}}</span>
            {{/if}}
            <span class="nogrow cp-unit-conv"><small>≈ {{@root.veh.speedAlt.max}} {{@root.veh.speedAltUnit}}</small></span>
        </span>
    </div>
     <div class="field">
        <label for="system.speed.acceleration">{{CPLocal "Accel"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.speed.acceleration" value="{{acceleration}}">
            <span class="nogrow">{{@root.veh.speedUnit}}</span>
        </span>
    </div>
     <div class="field">
        {{!-- The books print accel/decel as a pair ("ACC/DEC 18/30") — VEHICLE-SPEC.md §6 --}}
        <label for="system.speed.deceleration">{{CPLocal "Decel"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.speed.deceleration" value="{{deceleration}}">
            <span class="nogrow">{{@root.veh.speedUnit}}</span>
        </span>
    </div>

    {{!-- Accel/decel buttons — only when editable; they write speed.value, so on a locked compendium
          item they would fire item.update() and warn. Hidden (and unwired) when !editable. --}}
    {{#if @root.editable}}
    <div class="flexrow">
        <div class="field decel"><label class="fillwidth" style="text-align: center; font-size: larger">-</label></div>
        <div class="field accel"><label class="fillwidth" style="text-align: center; font-size: larger">+</label></div>
    </div>
    {{/if}}
   <div class="field">
       {{!-- Maneuver (safe) SPEED — a printed stat ("Maneuver Speed 400kph / Top 560kph"), distinct
             from the Maneuverability control-roll modifier below (VEHICLE-SPEC.md §6). --}}
        <label for="system.speed.maneuver" title="{{CPLocal "ManeuverSpeedFull"}}">{{CPLocal "ManeuverSpeed"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.speed.maneuver" value="{{maneuver}}">
            <span class="nogrow">{{@root.veh.speedUnit}}</span>
        </span>
    </div>
    {{/with}}
</div>

{{!-- Miscellaneous vehicle-only other --}}
<div class="field-list">
    <div class="field">
        <label for="system.passengers">{{CPLocal "Passengers"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.passengers" value="{{system.passengers}}"> 
        </span>
    </div>
    <div class="field">
        <label for="system.maneuverability.value" title="{{CPLocal "ManeuverabilityHint"}}">{{CPLocal "ManeuverabilityFull"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.maneuverability.value" value="{{system.maneuverability.value}}">
        </span>
    </div>
    {{!-- Travel range (raw value + unit; the sheet shows the converted unit too) --}}
    <div class="field">
        <label for="system.range">{{CPLocal "Range"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.range" value="{{system.range}}">
            {{#if @root.editable}}
            <select name="system.rangeUnit" class="nogrow cp-unit-select">
                <option value="mi" {{#if (equals system.rangeUnit "mi")}}selected{{/if}}>mi</option>
                <option value="km" {{#if (equals system.rangeUnit "km")}}selected{{/if}}>km</option>
            </select>
            {{else}}
            <span class="nogrow cp-unit-static">{{veh.rangeUnit}}</span>
            {{/if}}
            <span class="nogrow cp-unit-conv"><small>≈ {{veh.rangeAlt}} {{veh.rangeAltUnit}}</small></span>
        </span>
    </div>
    {{!-- Mass + cargo (audit-walk schema upgrade): value + unit, mirroring the speed/range pattern --}}
    <div class="field">
        <label for="system.mass.value">{{CPLocal "Mass"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.mass.value" value="{{system.mass.value}}">
            {{#if @root.editable}}
            <select name="system.mass.unit" class="nogrow cp-unit-select">
                <option value="tons" {{#if (equals system.mass.unit "tons")}}selected{{/if}}>tons</option>
                <option value="kg" {{#if (equals system.mass.unit "kg")}}selected{{/if}}>kg</option>
            </select>
            {{else}}
            <span class="nogrow cp-unit-static">{{system.mass.unit}}</span>
            {{/if}}
        </span>
    </div>
    <div class="field">
        <label for="system.cargo.value">{{CPLocal "Cargo"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.cargo.value" value="{{system.cargo.value}}">
            {{#if @root.editable}}
            <select name="system.cargo.unit" class="nogrow cp-unit-select">
                <option value="kg" {{#if (equals system.cargo.unit "kg")}}selected{{/if}}>kg</option>
                <option value="tons" {{#if (equals system.cargo.unit "tons")}}selected{{/if}}>tons</option>
            </select>
            {{else}}
            <span class="nogrow cp-unit-static">{{system.cargo.unit}}</span>
            {{/if}}
        </span>
    </div>
</div>

{{!-- Fuel — DEMOTED (VEHICLE-SPEC.md §4): the books print the fuel triad on ~1% of vehicles
      (range above is the real endurance stat), so it renders LAST, its gauge only appears once a
      capacity is recorded, and a locked sheet with no fuel data skips the block (veh.showFuel). --}}
{{#if @root.veh.showFuel}}
<div class="field-list">
    {{#with system.fuel}}
    {{#if max}}
    <div class="flexcol fillwidth span-two-cells">
        <div class="meter-gauge fillwidth">
            <span style="width: calc(100% * ({{value}}/{{max}}));" class="
            {{#if (compare value "<" (math max "/" 3))}}
            danger
            {{/if}}"></span>
        </div>
    </div>
    {{/if}}
    <div class="field">
        <label class="larger" for="system.fuel.value">{{CPLocal "Fuel"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.fuel.value" value="{{value}}">
            <span class="nogrow">/</span>
            <input type="number" name="system.fuel.max" value="{{max}}">
            {{#if @root.editable}}
            <select name="system.fuel.unit" class="nogrow cp-unit-select">
                <option value="gal" {{#if (equals unit "gal")}}selected{{/if}}>gal</option>
                <option value="liters" {{#if (equals unit "liters")}}selected{{/if}}>L</option>
            </select>
            {{else}}
            <span class="nogrow cp-unit-static">{{@root.veh.fuelCapSuffix}}</span>
            {{/if}}
        </span>
    </div>
     <div class="field">
        <label for="system.fuel.type">{{CPLocal "Type"}}</label>
        <span class="flexrow flex-pad">
            <input type="text" name="system.fuel.type" value="{{type}}">
        </span>
    </div>
   <div class="field">
        <label for="system.fuel.efficiency">{{CPLocal "Efficiency"}}</label>
        <span class="flexrow flex-pad">
            <input type="number" name="system.fuel.efficiency" value="{{efficiency}}">
            <span class="nogrow">{{@root.veh.fuelEffSuffix}}</span>
        </span>
    </div>
    {{/with}}
</div>
{{/if}}
</div>{{!-- /.cp-vehicle-item-fields --}}