<div class="field-list">
    {{> (template "fields/boolean") label="Equipped" edit="system.equipped"}}
    {{> (template "fields/number") label="Cost" edit="system.cost"}}
    {{> (template "fields/number") label="Weight" edit="system.weight"}}
    {{> (template "fields/string") label="Source" edit="system.source"}}

    {{!-- Services (Shopping #15): override how this item is treated when shopping is enabled. "Auto"
         infers from the source list / name; the others force gear / a recurring bill / a one-off.
         serviceMode/servicePeriod live ONLY on the `misc` data model, but this part doubles as the
         shared Cost/Weight/Source footer for every item type → gate the block to misc so it doesn't
         render (vestigially) on cyberware/weapons/armor/etc. --}}
    {{!-- serviceMode/servicePeriod persist in module flags (flags.cp2020-augmented.*): the base `misc`
         DataModel strips unknown system fields, so binding system.* silently dropped edits. The item
         sheet exposes the normalized `serviceMode`/`servicePeriod` (via serviceModeOf/servicePeriodOf). --}}
    {{#if (equals item.type "misc")}}
    <div class="field">
        <label for="flags.cp2020-augmented.serviceMode">{{CPLocal "ServiceMode"}}</label>
        <span class="flex-pad"></span>
        <select name="flags.cp2020-augmented.serviceMode">
            <option value="" {{#if (equals serviceMode "")}}selected{{/if}}>{{CPLocal "ServiceModeAuto"}}</option>
            <option value="gear" {{#if (equals serviceMode "gear")}}selected{{/if}}>{{CPLocal "ServiceModeGear"}}</option>
            <option value="recurring" {{#if (equals serviceMode "recurring")}}selected{{/if}}>{{CPLocal "ServiceModeRecurring"}}</option>
            <option value="oneoff" {{#if (equals serviceMode "oneoff")}}selected{{/if}}>{{CPLocal "ServiceModeOneoff"}}</option>
        </select>
    </div>
    {{#if (equals serviceMode "recurring")}}
    <div class="field">
        <label for="flags.cp2020-augmented.servicePeriod">{{CPLocal "ServicePeriod"}}</label>
        <span class="flex-pad"></span>
        <input class="textsize" name="flags.cp2020-augmented.servicePeriod" type="text" value="{{servicePeriod}}"/>
    </div>
    {{/if}}
    {{/if}}

    {{!-- P3 light emitter (misc gear + cyberware; SPECIAL-MECHANICS-PROPOSAL.md, D2 sheet-first).
         `system.mechLight` is a REAL field — the module extends the misc/cyberware DataModels at
         init (D1) — so the inputs bind directly; no flags detour. "Lit" is the runtime toggle a
         player flips; the token lights up only while the item is also equipped. --}}
    {{#if @root.mechFieldsEligible}}
    {{> (template "fields/boolean") label="MechLight" edit="system.mechLight.enabled"}}
    {{#if system.mechLight.enabled}}
    <div class="field">
        <label for="system.mechLight.shape">{{CPLocal "MechLightShape"}}</label>
        <span class="flex-pad"></span>
        <select name="system.mechLight.shape">
            <option value="cone" {{#if (equals system.mechLight.shape "cone")}}selected{{/if}}>{{CPLocal "MechLightShapeCone"}}</option>
            <option value="circle" {{#if (equals system.mechLight.shape "circle")}}selected{{/if}}>{{CPLocal "MechLightShapeCircle"}}</option>
        </select>
    </div>
    {{> (template "fields/number") label="MechLightBright" edit="system.mechLight.bright"}}
    {{> (template "fields/number") label="MechLightDim" edit="system.mechLight.dim"}}
    {{#if (equals system.mechLight.shape "cone")}}
    {{> (template "fields/number") label="MechLightAngle" edit="system.mechLight.angle"}}
    {{/if}}
    <div class="field">
        <label for="system.mechLight.color" title="{{CPLocal "MechLightColorHint"}}">{{CPLocal "MechLightColor"}}</label>
        <span class="flex-pad"></span>
        <input class="textsize" name="system.mechLight.color" type="text" value="{{system.mechLight.color}}" placeholder="#ffffff"/>
    </div>
    {{> (template "fields/boolean") label="MechLightOn" edit="system.mechLight.on"}}
    {{/if}}

    {{!-- P4 vision device (IR / low-light / thermograph / UV): changes how the wearer's token SEES.
         Mode options are assembled in _prepareContext (JS owns data; labels localized there). --}}
    {{> (template "fields/boolean") label="MechVision" edit="system.mechVision.enabled"}}
    {{#if system.mechVision.enabled}}
    <div class="field">
        <label for="system.mechVision.mode">{{CPLocal "MechVisionMode"}}</label>
        <span class="flex-pad"></span>
        <select name="system.mechVision.mode">
            {{#each @root.mechVisionModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
    </div>
    {{> (template "fields/number") label="MechVisionRange" edit="system.mechVision.range"}}
    {{> (template "fields/boolean") label="MechVisionOn" edit="system.mechVision.on"}}
    {{/if}}

    {{!-- P6 protection tags: passive gear the save engines consult (gas is live; flash/sonic are
         data-ready). Rows come from _prepareContext (JS owns the hazard list + labels). --}}
    {{> (template "fields/boolean") label="MechProtection" edit="system.mechProtection.enabled"}}
    {{#if system.mechProtection.enabled}}
    {{#each @root.mechProtectionRows}}
    <div class="field">
        <label>{{label}}</label>
        <span class="flexrow flex-pad">
            <label class="nogrow">{{immuneLabel}}</label>
            <input type="checkbox" name="system.mechProtection.{{key}}.immune" data-dtype="Boolean" {{#if immune}}checked{{/if}}>
            <label class="nogrow">{{modLabel}}</label>
            <input type="number" name="system.mechProtection.{{key}}.mod" value="{{mod}}">
        </span>
    </div>
    {{/each}}
    {{/if}}
    {{/if}}
</div>