{{!-- ACPA non-weapon system (Maximum Metal p.61-79). Mounted in a powered-armor body area; carries
      its own SOP so a hit can knock out this one system. Offensive weapons use the vehicleWeapon type. --}}

<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.SysCategoryTip'}}">
        <label>{{CPLocal "Vehicle.SysCategory"}}</label>
        <select name="system.category">
            <option value="utility"   {{#if (equals system.category "utility")}}selected{{/if}}>{{CPLocal "Vehicle.SysCatUtility"}}</option>
            <option value="sensor"    {{#if (equals system.category "sensor")}}selected{{/if}}>{{CPLocal "Vehicle.SysCatSensor"}}</option>
            <option value="movement"  {{#if (equals system.category "movement")}}selected{{/if}}>{{CPLocal "Vehicle.SysCatMovement"}}</option>
            <option value="defensive" {{#if (equals system.category "defensive")}}selected{{/if}}>{{CPLocal "Defensive"}}</option>
            <option value="safety"    {{#if (equals system.category "safety")}}selected{{/if}}>{{CPLocal "Vehicle.SysCatSafety"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.SysBodyAreaTip'}}">
        <label>{{CPLocal "Vehicle.SysBodyArea"}}</label>
        <select name="system.area">
            <option value="head"  {{#if (equals system.area "head")}}selected{{/if}}>{{CPLocal "Head"}}</option>
            <option value="torso" {{#if (equals system.area "torso")}}selected{{/if}}>{{CPLocal "Torso"}}</option>
            <option value="rArm"  {{#if (equals system.area "rArm")}}selected{{/if}}>{{CPLocal "Vehicle.AreaRArm"}}</option>
            <option value="lArm"  {{#if (equals system.area "lArm")}}selected{{/if}}>{{CPLocal "Vehicle.AreaLArm"}}</option>
            <option value="rLeg"  {{#if (equals system.area "rLeg")}}selected{{/if}}>{{CPLocal "Vehicle.AreaRLeg"}}</option>
            <option value="lLeg"  {{#if (equals system.area "lLeg")}}selected{{/if}}>{{CPLocal "Vehicle.AreaLLeg"}}</option>
        </select>
    </div>
    <div class="field" title="{{CPLocal 'Vehicle.SysMountTip'}}">
        <label>{{CPLocal "Vehicle.SysMount"}}</label>
        <select name="system.mount">
            <option value="internal" {{#if (equals system.mount "internal")}}selected{{/if}}>{{CPLocal "Vehicle.MountInternal"}}</option>
            <option value="external" {{#if (equals system.mount "external")}}selected{{/if}}>{{CPLocal "Vehicle.MountExternal"}}</option>
            <option value="either"   {{#if (equals system.mount "either")}}selected{{/if}}>{{CPLocal "Vehicle.MountEither"}}</option>
            <option value="retract"  {{#if (equals system.mount "retract")}}selected{{/if}}>{{CPLocal "Vehicle.MountRetractable"}}</option>
        </select>
    </div>
</div>

<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.SysSpacesTip'}}">
        <label>{{CPLocal "Spaces"}}</label><input type="number" step="0.25" name="system.spaces" value="{{system.spaces}}"/></div>
    <div class="field" title="{{CPLocal 'Vehicle.SysSPTip'}}">
        <label>{{CPLocal "SP"}}</label><input type="number" name="system.sp" value="{{system.sp}}"/></div>
    <div class="field" title="{{CPLocal 'Vehicle.SysSOPTip'}}">
        <label>{{CPLocal "Vehicle.SysSOP"}}</label><input type="number" name="system.sop" value="{{system.sop}}"/></div>
</div>

<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.SysWeightKgTip'}}">
        <label>{{CPLocal "Vehicle.SysWeightKg"}}</label><input type="number" name="system.weight" value="{{system.weight}}"/></div>
    <div class="field" title="{{CPLocal 'Vehicle.SysCostEbTip'}}">
        <label>{{CPLocal "Vehicle.SysCostEb"}}</label><input type="number" name="system.cost" value="{{system.cost}}"/></div>
    <div class="field" title="{{CPLocal 'Vehicle.SysSOPDamageTip'}}">
        <label>{{CPLocal "Vehicle.SysSOPDamage"}}</label><input type="number" name="system.sopDamage" value="{{system.sopDamage}}"/></div>
</div>

<div class="field-list">
    <div class="field" title="{{CPLocal 'Vehicle.SysDestroyedTip'}}">
        <label>{{CPLocal "Vehicle.SysDestroyed"}}</label><input type="checkbox" name="system.destroyed" {{#if system.destroyed}}checked{{/if}}/></div>
</div>
