{{!-- Life-tab biography notes: read-only view + Edit button (data-action="notes-edit"), or the
      ProseMirror editor when `notesEditing`. Shared by the main actor sheet AND the popped-out Life
      tab (CyberpunkActorTabSheet) so the same _cpActivateNotesEditor view/edit toggle wires both —
      the popout previously inlined a raw {{editor}}, whose native edit button our V2 sheet never
      wired, so editing was dead when popped out. --}}
<div class="biography cp-notes-editor" data-editor-target="system.notes">
    <div class="cp-notes-canvas {{#if notesEditing}}is-editing{{else}}is-viewing{{/if}}">
        {{#if editable}}
            {{#unless notesEditing}}
                <button
                    type="button"
                    class="cp-notes-edit"
                    data-action="notes-edit"
                    title="{{localize 'CYBERPUNK.LifeNotesEdit'}}"
                    aria-label="{{localize 'CYBERPUNK.LifeNotesEdit'}}"
                >
                    <i class="fas fa-edit"></i>
                </button>
            {{/unless}}
        {{/if}}

        {{#if notesEditing}}
            <prose-mirror
                class="cp-notes-prosemirror"
                name="system.notes"
                value="{{system.notes}}"
            >{{{system.notes}}}</prose-mirror>
        {{else}}
            <div class="cp-notes-view">
                {{{system.notes}}}
            </div>
        {{/if}}
    </div>
</div>
