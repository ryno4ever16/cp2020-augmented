<div class="field-list no-wrap">
    <div class="field">
        <label for="totalCyberCost">{{CPLocal "TotalEBVal"}}</label>
        <input name="totalCyberCost" type="number" value="{{gear.cyberCost}}" readonly>
    </div>
    <div class="field">
        <label for="system.stats.emp.humanity.loss">{{CPLocal "HumanityLoss"}}</label>
        <input class="not-editable" name="system.stats.emp.humanity.loss" type="number" value="{{system.stats.emp.humanity.loss}}" readonly>
    </div>
    {{#if system.stats.emp.cyberpsychosis}}
    <div class="field" title="{{system.stats.emp.cyberpsychosis.label}}">
        <label>{{CPLocal "Cyberpsychosis"}}</label>
        <input class="not-editable cp-cyberpsychosis-state" data-state="{{system.stats.emp.cyberpsychosis.state}}" type="text"
               value="{{system.stats.emp.cyberpsychosis.label}}"
               style="{{#if system.stats.emp.cyberpsychosis.lost}}color:#ff4040;font-weight:bold;{{else if system.stats.emp.cyberpsychosis.atRisk}}color:#ffaa33;{{/if}}" readonly>
    </div>
    {{/if}}
</div>

<header class="cyberware-header">
    <h2>{{CPLocal "ActiveChipware"}}</h2>
</header>
<div class="chip-scroll-wrapper">
  <div class="chipware-container {{#unless chipsActive.length}}is-empty{{/unless}}" data-drop-target="active-chips">
    {{#if chipsActive.length}}
      {{#each chipsActive as |chip|}}
        {{#with chip.system}}
          <div class="chipware field gear full-width"
               data-full="{{chip.name}}"
               style="background-image: url('systems/cyberpunk2020/img/chip.png')"
               data-item-id="{{chip.id}}"
               draggable="true">
            <span class="chip-name">
              <span class="chip-name-text">{{chip.name}}</span>
            </span>
            <div class="chipware-slot item-unequip" data-item-id="{{chip.id}}" draggable="false">X</div>
          </div>
        {{/with}}
      {{/each}}
    {{else}}
      <div class="chipware-dropzone" data-drop-target="active-chips"></div>
    {{/if}}
  </div>
</div>
{{!-- Active Cyberware header. For a full borg the whole body map IS the chassis, so the chassis name
      and its controls fold into this header (no dedicated segment): click the name to open the chassis
      item, ⊗ clears the whole loadout (options → Carried, non-destructive), 🗑 removes the chassis
      (prompting what to do with its attached options). The chassis part is absent for a normal char. --}}
<header class="cyberware-header cp-active-cyber-header">
    <h2>{{CPLocal "ActiveCyberware"}}</h2>
    {{#if borgChassis}}
    <span class="cp-chassis-inline">
        <span class="cp-chassis-name item-edit" data-item-id="{{borgChassis.id}}" title="{{CPLocal 'BorgChassisTip'}}">{{borgChassis.name}}</span>
        {{#if borgChassis.loadoutCount}}<a class="cp-group-remove" data-item-id="{{borgChassis.id}}" title="{{CPLocal 'BorgChassisClearTip'}}">&#8855;</a>{{/if}}
        <a class="cp-chassis-delete" data-item-id="{{borgChassis.id}}" title="{{CPLocal 'BorgChassisDeleteTip'}}">&#128465;</a>
    </span>
    {{/if}}
</header>


<div class="active-cyberware" style="background-image: url('systems/cyberpunk2020/img/black_gray_grid.png')">
    <div class="active-cyberware-right" >
        {{#each cyberwareSegmentsRight}}
            <section class="field-list cyberware-field-list active-cyberware-segment"
            data-drop-target="zone:{{this.area}}">
            <button type="button">{{this.areaLabel}}{{#if this.slotTotal}} <span class="cp-capacity-badge" title="{{CPLocal 'ZoneOptionSpacesTip'}}">{{this.slotUsed}}/{{this.slotTotal}}</span>{{/if}}</button>
            {{#each (lookup ../cyberZoneTrees this.area) as |node|}}
                {{> "modules/cp2020-augmented/templates/actor/parts/cyber-zone-node.hbs" node=node}}
            {{/each}}
            </section>
        {{/each}}
    </div>

    <div class="anatomy-container" style="background-image: url('systems/cyberpunk2020/img/black_gray_grid.png');">
        <select class="anatomy-select" title="{{CPLocal "AnatomySelectTip"}}">
            {{#each anatomyOptions as |opt|}}
            <option value="{{opt.key}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
        </select>
        {{!-- V14 strips <object> SVG embeds during sheet HTML rendering, so the male SVG vanished.
             <img> renders both the SVG and the female PNG fine; CSS sizes #anatomy-img and
             img#anatomy-img adds object-fit:contain. (anatomy.svg flag retained for callers.) --}}
        <img src="{{anatomy.src}}" id="anatomy-img" alt="anatomy"/>
    </div>
    <div class="active-cyberware-left">
        {{#each cyberwareSegmentsLeft}}
            <section class="field-list cyberware-field-list active-cyberware-segment"
                data-drop-target="zone:{{this.area}}">
                <button type="button">{{this.areaLabel}}{{#if this.slotTotal}} <span class="cp-capacity-badge" title="{{CPLocal 'ZoneOptionSpacesTip'}}">{{this.slotUsed}}/{{this.slotTotal}}</span>{{/if}}</button>
                {{#each (lookup ../cyberZoneTrees this.area) as |node|}}
                    {{> "modules/cp2020-augmented/templates/actor/parts/cyber-zone-node.hbs" node=node}}
                {{/each}}
            </section>
         {{/each}}
    </div>
</div>

{{!-- Carried Options: the parts bin — cyberware owned but not installed (equipped=false). Distinct
      from the active body map above; this is also where a new implant lands. Drop a piece here to
      uninstall (carry) it, drag one onto a limb zone or a host implant to (re)install it. Nothing here
      is destroyed unless the player deletes it deliberately. Always shown so it's a stable drop target. --}}
<header class="cyberware-header">
    <h2>{{CPLocal "CarriedOptions"}}</h2>
</header>
<div class="carried-options field-list" data-drop-target="cyber-inventory" title="{{CPLocal 'CarriedOptionsTip'}}">
    {{#each carriedCyber as |cyber|}}
        <div class="field gear item-edit full-width item cp-carried" data-item-id="{{cyber.id}}" draggable="true">
            <label>{{cyber.name}}</label>
            {{#with cyber.system}}<span>{{CPLocal "HumanityLossAbbrev"}}: {{humanityLoss}}</span>{{/with}}
            <span class="flex-pad"></span>
            <span class="item-delete" data-item-id="{{cyber.id}}" title="{{CPLocal 'Delete'}}">X</span>
        </div>
    {{/each}}
    {{#unless carriedCyber.length}}<div class="inactive cp-carried-empty">{{CPLocal "DragItemsPrompt"}}</div>{{/unless}}
</div>

{{!-- Internal / other: installed cyberware with no anatomical zone (e.g. an implant with no MountZone).
      Shown so nothing installed is hidden; uninstall (⏏) sends it to Carried Options like any implant. --}}
{{#if cyberOther.length}}
<header class="cyberware-header">
    <h2>{{CPLocal "CyberInternal"}}</h2>
</header>
<div class="cyber-internal field-list">
    {{#each cyberOther as |cyber|}}
        <div class="field gear item-edit full-width item" data-item-id="{{cyber.id}}" draggable="true">
            <label>{{cyber.name}}</label>
            {{#with (lookup @root.cpActiveBadges cyber.id)}}<span class="cp-active-badge" title="{{this}}"></span>{{/with}}
            {{#with cyber.system}}<span class="cp-hl">{{CPLocal "HumanityLossAbbrev"}}: {{humanityLoss}}</span>{{/with}}
            <span class="flex-pad"></span>
            <span class="item-unequip cp-uninstall" data-item-id="{{cyber.id}}" draggable="false" title="{{CPLocal 'CyberUninstall'}}">&#9167;</span>
        </div>
    {{/each}}
</div>
{{/if}}