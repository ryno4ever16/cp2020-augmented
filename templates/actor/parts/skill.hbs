{{!-- Really I want there to be the same kind of deleting for items and skills, but there's not enough real estate to add the Xs, and too much interactivity to move things around. May need some UI thinking --}}
<div class="field skill" data-item-id="{{skill.id}}">
    <label class="skill-roll action" data-skill-id="{{skill.id}}">{{skill.name}}</label>
    {{#with skill.system}}
        <label class="chip-toggle" data-skill-id="{{../skill.id}}">
            <div class="skill-stat-display">
                {{~#if isRoleSkill~}}
                    {{CPLocal (properCase stat)}} [{{CPLocal "Role"}}]
                {{~else}}
                    {{CPLocal (properCase stat)}}
                {{~/if~}}
            </div>
            <div class="chip-icon {{#unless isChipped}}inactive{{/unless}}"></div>
            <input class="chip-toggle-checkbox" type="checkbox" data-skill-id="{{../skill.id}}" {{checked isChipped}} {{#if autoChipped}}title="{{CPLocal 'ControlledByChip'}}"{{/if}} />
        </label>

    <span class="item-controls">
        <span class="skill-mod-toggle">
        <input type="checkbox" class="skill-ask-mod" data-skill-id="{{../skill.id}}" {{checked askMods}}>
        </span>
        <i class="fas fa-edit item-edit"   data-item-id="{{../skill.id}}"></i>
        <i class="fas fa-trash item-delete" data-item-id="{{../skill.id}}"></i>
    </span>

    <input type="number" data-skill-id="{{../skill.id}}" class="skill-level smallnumber nogrow"
        value="{{#if isChipped}}{{chipLevel}}{{else}}{{level}}{{/if}}"
        {{#if autoChipped}}readonly title="{{CPLocal 'ControlledByChip'}}"{{else}}{{#if @root.ip.locked}}readonly title="{{CPLocal 'IpSkillLockToggle'}}"{{/if}}{{/if}}
    />
    {{/with}}

    {{!-- IP tracker: banked IP / cost, GM-only pending pip, and the self-service level-up arrow. --}}
    {{#if @root.ip.enabled}}
    {{#with (lookup @root.ipBySkill skill.id) as |ipd|}}
    <span class="ip-cluster" title="{{CPLocal 'IpBanked'}} {{ipd.banked}} / cost {{ipd.cost}}">
        {{#if @root.ip.showPending}}{{#if ipd.pending}}<span class="ip-pending-pip" title="{{CPLocal 'IpPendingPip'}}">+{{ipd.pending}}</span>{{/if}}{{/if}}
        <span class="ip-banked">{{ipd.banked}}/{{ipd.cost}}</span>
        {{#if ipd.canLevel}}<i class="fas fa-arrow-up ip-level-up action" data-skill-id="{{skill.id}}" title="{{CPLocal 'IpLevelUp'}} ({{ipd.cost}} IP)"></i>{{/if}}
    </span>
    {{/with}}
    {{/if}}
</div>