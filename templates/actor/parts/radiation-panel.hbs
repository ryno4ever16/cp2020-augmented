{{!--
  radiation-panel.hbs — GM-only Deep Space radiation hub (R3b). Included from combat.hbs, guarded on
  `radiation.show` (GM + the actor actually carries radiation — a marker, current exposure, or lifetime
  history). Shows the running exposure, lifetime history,
  the actor's RSP, and any active radiation stat loss, plus the four GM controls (apply dose to this actor,
  roll the long-term reference, clear the current exposure, cure the stat loss). The .cp-rad-* buttons are
  handled by _cpActivateRadiationControls in module/actor/actor-sheet.js. Readout values are built in
  _prepareContext. i18n via CPLocal; no HTML/CSS in JS.
--}}
<section class="radiation-section cp-radiation-panel">
  <header>
    <h2 title="{{CPLocal 'RadPanelHint'}}">☢ {{CPLocal "RadPanelHeader"}}</h2>
  </header>

  <div class="field">
    <label title="{{CPLocal 'RadPanelExposureHint'}}">{{CPLocal "RadPanelExposure"}}</label>
    <span class="flex-pad"></span>
    <span class="cp-rad-readout">{{radiation.exposure}}</span>
  </div>
  <div class="field">
    <label title="{{CPLocal 'RadPanelHistoryHint'}}">{{CPLocal "RadPanelHistory"}}</label>
    <span class="flex-pad"></span>
    <span class="cp-rad-readout">{{radiation.history}}</span>
  </div>
  <div class="field">
    <label title="{{CPLocal 'RadPanelRspHint'}}">{{CPLocal "RadPanelRsp"}}</label>
    <span class="flex-pad"></span>
    <span class="cp-rad-readout">{{radiation.rsp}}</span>
  </div>
  {{#if radiation.statLoss}}
  <div class="field cp-rad-statloss-row">
    <label>{{CPLocal "RadPanelStatLoss"}}</label>
    <span class="flex-pad"></span>
    <span class="cp-rad-readout">{{radiation.statLoss}}</span>
  </div>
  {{/if}}

  <div class="radiation-actions">
    <button type="button" class="cp-rad-apply" title="{{CPLocal 'RadBtnApplyHint'}}">☢ {{CPLocal "RadBtnApply"}}</button>
    <button type="button" class="cp-rad-longterm" title="{{CPLocal 'RadBtnLongTermHint'}}">🧬 {{CPLocal "RadBtnLongTerm"}}</button>
    <button type="button" class="cp-rad-clear" title="{{CPLocal 'RadBtnClearHint'}}">{{CPLocal "RadBtnClear"}}</button>
    <button type="button" class="cp-rad-cure" title="{{CPLocal 'RadBtnCureHint'}}">{{CPLocal "RadBtnCure"}}</button>
    <button type="button" class="cp-rad-reset" title="{{CPLocal 'RadBtnResetHint'}}">🗑 {{CPLocal "RadBtnReset"}}</button>
  </div>
</section>
