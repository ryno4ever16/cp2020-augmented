{{!-- Status strip (§3c hybrid): one pill per ACTIVE influence, assembled in _prepareContext
      (cpStatusRows — JS owns the data, this template only lays it out). Renders nothing while
      idle. The × quick-toggle carries the boolean path _cpActivateStatusStrip writes false.
      Collapsible (native <details>): a compact summary by default so a long list doesn't crowd the
      header; expands to the pills on click. Open state persists via cpStatusOpen. --}}
{{#if cpShowStrip}}
<details class="cp-status-details" {{#if cpStatusOpen}}open{{/if}}>
<summary class="cp-status-summary">
    <span class="cp-status-icon">&#9888;</span>
    <span class="cp-status-count">{{#if cpStatusRows.length}}{{CPLocal "StatusStripSummary" count=cpStatusRows.length}}{{else}}{{CPLocal "StatusStripSummaryEmpty"}}{{/if}}</span>
</summary>
<div class="cp-status-strip">
    {{#each cpStatusRows}}
    <span class="cp-status-pill cp-kind-{{kind}}" title="{{title}}">
        <span class="cp-pill-kind">{{kindLabel}}</span>
        <span class="cp-pill-text">{{text}}</span>
        {{#if togglePath}}
        <a class="cp-pill-off" data-item-id="{{itemId}}" data-toggle-path="{{togglePath}}"
           title="{{CPLocal "StatusStripOff"}}">&times;</a>
        {{/if}}
        {{#if clearAddiction}}
        <a class="cp-pill-off" data-action="clear-addiction" data-drug="{{drugName}}"
           title="{{CPLocal "StatusStripClearAddiction"}}">&times;</a>
        {{/if}}
        {{#if clearDrug}}
        <a class="cp-pill-off" data-action="clear-drug" data-item-id="{{itemId}}"
           data-penalty="{{drugPenalty}}" title="{{CPLocal "StatusStripClearDrug"}}">&times;</a>
        {{/if}}
    </span>
    {{/each}}
    {{!-- Q5: which vision device governs sight (auto = longest range; Natural suspends overrides).
         Unnamed on purpose — the choice persists via the change handler into an actor flag. --}}
    {{#if cpVisionPick}}
    <span class="cp-status-pill cp-kind-vision" title="{{CPLocal "VisionPickHint"}}">
        <span class="cp-pill-kind">{{CPLocal "StatusStripKindVision"}}</span>
        <select class="cp-vision-pick">
            {{#each cpVisionPick.options}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
    </span>
    {{/if}}
</div>
</details>
{{/if}}
