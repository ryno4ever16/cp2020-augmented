{{!-- V2 sheet: the outer <form> element is provided by ApplicationV2 (tag:"form" in DEFAULT_OPTIONS).
     Template content starts directly with the header. --}}
    {{!-- ACPA (powered armor) sheet — rendered for isACPA vehicles via the sheet's _prepareContext.
          Same actor type + data model + combat code as a vehicle; this is a powered-armor LAYOUT.
          The detailed design/construction system (frame, Reality Interface, Reflex/Control, systems)
          is being added incrementally below the existing combat fields.
          V2 requires each PART to render a SINGLE root element, so wrap everything in one div. --}}
<div class="cp-acpa-sheet-root flexcol">
    <header class="cyberheader">
        <div class="flexrow">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
            <div class="flexcol" style="flex:1; margin-left:8px;">
                <h1 class="title"><input type="search" class="field-value" name="name" value="{{actor.name}}" autocomplete="off" data-lpignore="true" data-1p-ignore data-bwignore/></h1>
                <div class="fieldrow">
                    <div class="field" title="{{CPLocal 'Vehicle.AcpaCheckboxTip'}}">
                        <label>{{CPLocal "Vehicle.AcpaLabel"}}</label>
                        <input type="checkbox" name="system.isACPA" {{#if system.isACPA}}checked{{/if}}/>
                    </div>
                    <div class="field" title="{{CPLocal 'Vehicle.RulesetTip'}}">
                        <label>{{CPLocal "Vehicle.RulesetLabel"}}</label>
                        <span class="cp-ruleset-badge">{{ruleSystemLabel}}</span>
                    </div>
                    {{#if controlEnabled}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="controlRoll" title="{{CPLocal 'Vehicle.ControlRollTipAcpa'}}">{{CPLocal "Vehicle.ControlBtnAcpa"}}</button>
                    </div>
                    {{/if}}
                    {{#if damageEnabled}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="vehicleDamage" title="{{CPLocal 'Vehicle.DamageTipAcpa'}}">{{CPLocal "Vehicle.DamageBtn"}}</button>
                    </div>
                    {{/if}}
                    {{#if mmOn}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="acpaMelee" title="{{CPLocal 'Vehicle.MeleeTip'}}">{{CPLocal "Vehicle.MeleeBtn"}}</button>
                    </div>
                    <div class="field cp-header-action">
                        <button type="button" data-action="acpaRepair" title="{{CPLocal 'Vehicle.RepairTip'}}">{{CPLocal "Vehicle.RepairBtn"}}</button>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </header>

    <div class="sheet-body flexcol" style="overflow-y:auto;">

        {{!-- Pilot — deliberately the FIRST section: linking a pilot is the first thing a user
              looks for on a suit, and it drives effective REF + the pilot damage route. --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.PilotHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.PilotLinkTip'}}">
                <label>{{CPLocal "Vehicle.PilotLabel"}}</label>
                <select name="system.pilotId">
                    <option value="" {{#unless system.pilotId}}selected{{/unless}}>{{CPLocal "Vehicle.PilotNoneOption"}}</option>
                    {{#each pilotChoices}}<option value="{{id}}" {{#if (equals ../system.pilotId id)}}selected{{/if}}>{{name}}</option>{{/each}}
                </select>
            </div>
            {{#if linkedPilotName}}
            <div class="field" title="{{CPLocal 'Vehicle.LinkedPilotRefTip'}}">
                <label>{{linkedPilotName}} REF</label><input type="number" class="not-editable" value="{{linkedPilotRef}}" readonly/></div>
            {{else}}
            <div class="field" title="{{CPLocal 'Vehicle.PilotRefManualTip'}}">
                <label>{{CPLocal "Vehicle.PilotRefManualLabel"}}</label><input type="number" name="system.pilotRef" value="{{system.pilotRef}}"/></div>
            {{/if}}
            <div class="field" title="{{CPLocal 'Vehicle.EffectiveRefTip'}}">
                <label>{{CPLocal "Vehicle.EffectiveRefLabel"}}</label><input type="number" class="not-editable" value="{{system.effectiveRef}}" readonly/></div>
        </div>
        {{/if}}

        {{!-- Chassis & Armor --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.ChassisArmorHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.ChassisStrTip'}}">
                <label>{{CPLocal "Vehicle.ChassisStrLabel"}}</label><input type="number" name="system.str" value="{{system.str}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.BodyValueTip'}}">
                <label>{{CPLocal "Vehicle.BodyValueLabel"}}</label><input type="number" class="not-editable" value="{{system.bodyValue}}" readonly/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.ArmorSpTip'}}">
                <label>{{CPLocal "Vehicle.ArmorSpLabel"}}</label><input type="number" name="system.sp.front" value="{{system.sp.front}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.ArmorValueTipAcpa'}}">
                <label>{{CPLocal "Vehicle.ArmorValueLabel"}}</label><input type="number" class="not-editable" value="{{system.armorValue.front}}" readonly/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.SdpCurrentTip'}}">
                <label>{{CPLocal "Vehicle.SdpCurrentLabel"}}</label><input type="number" name="system.sdp.value" value="{{system.sdp.value}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.SdpMaxTip'}}">
                <label>{{CPLocal "Vehicle.SdpMaxLabel"}}</label><input type="number" name="system.sdp.max" value="{{system.sdp.max}}"/></div>
            {{#if system.destroyed}}<div class="field"><label class="cp-vehicle-destroyed">{{CPLocal "Vehicle.Destroyed"}}</label></div>{{/if}}
        </div>

        {{!-- Linear Frame — derived from chassis STR via the Chassis Inventory Table (MM p.61-62). --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.LinearFrameHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.ToughnessTip'}}">
                <label>{{CPLocal "Vehicle.ToughnessLabel"}}</label><input type="number" class="not-editable" value="{{system.toughness}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.FrameDamModTip'}}">
                <label>{{CPLocal "Vehicle.FrameDamModLabel"}}</label><input type="text" class="not-editable" value="{{system.damMod}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.LiftKgTip'}}"><label>{{CPLocal "Vehicle.LiftKgLabel"}}</label><input type="number" class="not-editable" value="{{system.lift}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.CarryKgTip'}}"><label>{{CPLocal "Vehicle.CarryKgLabel"}}</label><input type="number" class="not-editable" value="{{system.carry}}" readonly/></div>
        </div>
        <p style="opacity:0.6; font-size:0.78em; margin:2px 0;">{{CPLocal "Vehicle.FrameSdpNote"}}</p>
        <div class="field-list">
            <div class="field"><label>{{CPLocal "Vehicle.HeadLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.head}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.TorsoLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.torso}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.RArmLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.rArm}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.LArmLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.lArm}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.RLegLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.rLeg}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.LLegLabel"}}</label><input type="number" class="not-editable" value="{{system.frameSDPMax.lLeg}}" readonly/></div>
        </div>
        {{/if}}

        {{!-- Reality Interface & Reflex/Control — the suit's "user interface" (MM p.64-65). The
              interface sets DFB (weapon to-hit) + its SIB contribution; reflex/control sets the REF cap. --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.RealityInterfaceHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.RealityInterfaceTip'}}">
                <label>{{CPLocal "Vehicle.RealityInterfaceLabel"}}</label>
                <select name="system.realityInterface">
                    {{#each realityInterfaceChoices}}<option value="{{key}}" {{#if (equals ../system.realityInterface key)}}selected{{/if}}>{{label}}</option>{{/each}}
                </select>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.ReflexControlTip'}}">
                <label>{{CPLocal "Vehicle.ReflexControlLabel"}}</label>
                <select name="system.reflexControl">
                    {{#each reflexControlChoices}}<option value="{{key}}" {{#if (equals ../system.reflexControl key)}}selected{{/if}}>{{label}}</option>{{/each}}
                </select>
            </div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.DfbToHitTip'}}">
                <label>{{CPLocal "Vehicle.DfbToHitLabel"}}</label><input type="number" class="not-editable" value="{{system.dfb}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.InterfaceSibTip'}}">
                <label>{{CPLocal "Vehicle.InterfaceSibLabel"}}</label><input type="number" class="not-editable" value="{{system.interfaceSib}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.MaxRefTip'}}">
                <label>{{CPLocal "Vehicle.MaxRefLabel"}}</label><input type="number" class="not-editable" value="{{system.maxRef}}" readonly/></div>
            {{#if userIsGM}}
            <div class="field" title="{{CPLocal 'Vehicle.RefCapOverrideTip'}}">
                <label>{{CPLocal "Vehicle.RefCapOverrideLabel"}}</label><input type="number" name="system.refCapOverride" value="{{system.refCapOverride}}" min="0"/></div>
            {{/if}}
        </div>
        {{!-- (Pilot link / linked REF / effective REF moved to the top-of-sheet Pilot section.) --}}
        {{!-- ACPA combat-model pole (Unit D): the GM sets it; everyone sees the read-only effective model. --}}
        <div class="field-list">
            {{#if userIsGM}}
            <div class="field" title="{{CPLocal 'Vehicle.AcpaCombatModelTip'}}">
                <label>{{CPLocal "Vehicle.AcpaCombatModelLabel"}}</label>
                <select name="system.acpaCombatModel">
                    <option value="" {{#unless system.acpaCombatModel}}selected{{/unless}}>{{CPLocal "Vehicle.AcpaModeAuto"}}</option>
                    <option value="detailed" {{#if (equals system.acpaCombatModel "detailed")}}selected{{/if}}>{{CPLocal "Vehicle.AcpaModeDetailed"}}</option>
                    <option value="quickkill" {{#if (equals system.acpaCombatModel "quickkill")}}selected{{/if}}>{{CPLocal "Vehicle.AcpaModeQuickKill"}}</option>
                </select>
            </div>
            {{/if}}
            {{#if acpaModeEffective}}
            <div class="field" title="{{CPLocal 'Vehicle.AcpaModeEffectiveTip'}}">
                <label>{{CPLocal "Vehicle.AcpaModeEffectiveLabel"}}</label><input type="text" class="not-editable" value="{{acpaModeEffectiveLabel}}" readonly/></div>
            {{/if}}
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.CommandComputerTip'}}">
                <label>{{CPLocal "Vehicle.CommandComputerLabel"}}</label><input type="checkbox" name="system.commandComputer" {{#if system.commandComputer}}checked{{/if}}/></div>
        </div>
        <p style="opacity:0.6; font-size:0.78em; margin:2px 0;">{{CPLocal "Vehicle.SibNote"}}</p>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.SibInitiativeTip'}}">
                <label>{{CPLocal "Vehicle.SibInitiativeLabel"}}</label><input type="number" class="not-editable" value="{{system.sib}}" readonly/>
                {{#if system.sibOverloaded}}<span class="cp-sib-overload" style="color:#b00; font-size:0.72em; font-weight:600; margin-left:6px;" title="{{CPLocal 'Vehicle.SibOverloadTip'}}">{{CPLocal "Vehicle.SibOverloadBadge"}}</span>{{/if}}</div>
            <div class="field" title="{{CPLocal 'Vehicle.TotalWtKgTip'}}">
                <label>{{CPLocal "Vehicle.TotalWtKgLabel"}}</label><input type="number" class="not-editable" value="{{system.totalWeight}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.ArmorWtKgTip'}}">
                <label>{{CPLocal "Vehicle.ArmorWtKgLabel"}}</label><input type="number" class="not-editable" value="{{system.armorWeight}}" readonly/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.RunSpeedTip'}}">
                <label>{{CPLocal "Vehicle.RunSpeedLabel"}}</label><input type="number" class="not-editable" value="{{system.runM}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.JumpStandingTip'}}">
                <label>{{CPLocal "Vehicle.JumpStandingLabel"}}</label><input type="number" class="not-editable" value="{{system.jumpStanding}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.JumpRunningTip'}}">
                <label>{{CPLocal "Vehicle.JumpRunningLabel"}}</label><input type="number" class="not-editable" value="{{system.jumpRunning}}" readonly/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.TrooperCapTip'}}">
                <label>{{CPLocal "Vehicle.TrooperCapLabel"}}</label><input type="number" name="system.trooperCapacity" value="{{system.trooperCapacity}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.ExtraSysWtTip'}}">
                <label>{{CPLocal "Vehicle.ExtraSysWtLabel"}}</label><input type="number" name="system.systemsWeight" value="{{system.systemsWeight}}"/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.CarriedGearTip'}}">
                <label>{{CPLocal "Vehicle.CarriedGearLabel"}}</label><input type="number" name="system.carriedGearKg" value="{{system.carriedGearKg}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.ExternalLoadTip'}}">
                <label>{{CPLocal "Vehicle.ExternalLoadLabel"}}</label><input type="number" class="not-editable" value="{{system.externalLoadKg}}" readonly/></div>
        </div>
        {{/if}}

        {{!-- Pilot & Systems. Cyberlinked / Fire Control / Damage Control / Composite Armor are VEHICLE-chapter
             options absent from PA construction (MM p.61-70) — the suit's book equivalents are the Reality
             Interface DFB and Reflex/Control systems — so they are not rendered on the ACPA sheet. --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.PilotSystemsHeader"}}</h2>
        {{#if mmOn}}
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.SensorsRadarTipAcpa'}}">
                <label>{{CPLocal "Vehicle.SensorsRadarLabel"}}</label><input type="checkbox" name="system.sensors" {{#if system.sensors}}checked{{/if}}/></div>
            <div class="field" title="{{CPLocal 'Vehicle.AntiMissileTipAcpa'}}">
                <label>{{CPLocal "Vehicle.AntiMissileLabel"}}</label><input type="checkbox" name="system.antiMissile" {{#if system.antiMissile}}checked{{/if}}/></div>
        </div>
        {{/if}}

        {{#if mmOn}}{{> "modules/cp2020-augmented/templates/actor/parts/countermeasures.hbs"}}{{/if}}

        {{!-- ACPA Combat Status (written by the damage resolver + per-round ticks; editable for field repairs). --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.CombatStatusHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.StrDamageTip'}}">
                <label>{{CPLocal "Vehicle.StrDamageLabel"}}</label><input type="number" name="system.strDamage" value="{{system.strDamage}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.RefDamageTip'}}">
                <label>{{CPLocal "Vehicle.RefDamageLabel"}}</label><input type="number" name="system.refDamage" value="{{system.refDamage}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.PowerHrsTip'}}">
                <label>{{CPLocal "Vehicle.PowerHrsLabel"}}</label><input type="number" name="system.powerHours" value="{{system.powerHours}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.CoolingMinTipAcpa'}}">
                <label>{{CPLocal "Vehicle.CoolingMinLabel"}}</label><input type="number" step="0.05" name="system.coolingTimer" value="{{system.coolingTimer}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.HeatstrokeTip'}}">
                <label>{{CPLocal "Vehicle.HeatstrokeLabel"}}</label><input type="number" name="system.heatstrokeLevel" value="{{system.heatstrokeLevel}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.InterfaceOutTip'}}">
                <label>{{CPLocal "Vehicle.InterfaceOutLabel"}}</label><input type="number" name="system.interfaceOut" value="{{system.interfaceOut}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.SeizedRdsTipAcpa'}}">
                <label>{{CPLocal "Vehicle.SeizedRdsLabel"}}</label><input type="number" name="system.seizeUp" value="{{system.seizeUp}}"/></div>
        </div>
        {{/if}}

        {{!-- Weapons = embedded vehicleWeapon Items. --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.WeaponsHeader"}}</h2>
        <div class="cp-weapons">
            {{#each weapons as |weapon|}}
            <div class="field-list cp-weapon-row">
                <img class="cp-weapon-img" src="{{weapon.img}}" width="24" height="24"/>
                <span class="cp-weapon-name" title="{{weapon.system.weaponClass}} · {{weapon.system.mountType}} mount"><b>{{weapon.name}}</b>{{#if weapon.system.activeShell}} <span style="opacity:0.7;font-size:0.85em;">▸ {{weapon.system.activeShell}}</span>{{/if}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponPenTip'}}">Pen {{weapon.system.penetration}}{{#if weapon.system.ap}} AP{{/if}}{{#if weapon.system.heat}} HEAT{{/if}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponRofTip'}}">ROF {{weapon.system.rof}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponArcTip'}}">{{weapon.system.arc}}</span>
                {{#if @root.damageEnabled}}<button type="button" data-action="weaponFire" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponFireTip'}}">🎯</button>{{/if}}
                <button type="button" data-action="weaponEdit" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponEditTip'}}">✎</button>
                <button type="button" data-action="weaponDelete" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponDeleteTip'}}">✕</button>
            </div>
            {{/each}}
            <button type="button" data-action="weaponAdd" title="{{CPLocal 'Vehicle.WeaponAddTip'}}">{{CPLocal "Vehicle.WeaponAddBtn"}}</button>
            <p style="opacity:0.6; font-size:0.78em; margin-top:2px;">{{CPLocal "Vehicle.WeaponsDragNote"}}</p>
        </div>
        {{/if}}

        {{!-- Non-weapon systems = embedded acpaSystem Items (utility/sensor/movement/defensive/safety). --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.SystemsHeader"}}</h2>
        <div class="cp-weapons">
            {{#each acpaSystems as |sys|}}
            <div class="field-list cp-weapon-row">
                <img class="cp-weapon-img" src="{{sys.img}}" width="24" height="24"/>
                <span class="cp-weapon-name" title="{{sys.system.category}} system"><b>{{sys.name}}</b>{{#if sys.system.destroyed}} <span class="cp-acpa-system-destroyed">✖</span>{{/if}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.SystemBodyAreaTip'}}">{{sys.system.area}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.SystemSpacesTip' mount=sys.system.mount}}">{{sys.system.spaces}} sp</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.SystemSdpStatTip' damage=sys.system.sdpDamage}}">SDP {{sys.system.sdp}}</span>
                <button type="button" data-action="acpaSystemEdit" data-system-id="{{sys.id}}" title="{{CPLocal 'Vehicle.SystemEditTip'}}">✎</button>
                <button type="button" data-action="acpaSystemDelete" data-system-id="{{sys.id}}" title="{{CPLocal 'Vehicle.SystemDeleteTip'}}">✕</button>
            </div>
            {{/each}}
            <button type="button" data-action="acpaSystemAdd" title="{{CPLocal 'Vehicle.SystemAddTip'}}">{{CPLocal "Vehicle.SystemAddBtn"}}</button>
            <p style="opacity:0.6; font-size:0.78em; margin-top:2px;">{{CPLocal "Vehicle.SystemsDragNote"}}</p>
        </div>
        {{!-- Per-area spaces budget (used / available; internal + external). --}}
        <p style="opacity:0.6; font-size:0.78em; margin:4px 0 2px;">{{#if acpaSystemsCost}}{{{CPLocal "Vehicle.SpacesNoteWithCost" weight=system.mountedSystemsWeight cost=acpaSystemsCost}}}{{else}}{{{CPLocal "Vehicle.SpacesNote" weight=system.mountedSystemsWeight}}}{{/if}}</p>
        <table style="width:100%; font-size:0.82em; border-collapse:collapse;">
            <thead><tr style="opacity:0.7;"><th style="text-align:left;">{{CPLocal "Vehicle.SpacesAreaHeader"}}</th><th>{{CPLocal "Vehicle.SpacesInternalHeader"}}</th><th>{{CPLocal "Vehicle.SpacesExternalHeader"}}</th></tr></thead>
            <tbody>
            {{#each acpaSpaceRows as |row|}}
            <tr>
                <td style="text-align:left;">{{row.label}}</td>
                <td style="text-align:center;" class="{{#if row.overInt}}cp-acpa-spaces-over{{/if}}">{{row.usedInt}} / {{row.availInt}}</td>
                <td style="text-align:center;" class="{{#if row.overExt}}cp-acpa-spaces-over{{/if}}">{{row.usedExt}} / {{row.availExt}}</td>
            </tr>
            {{/each}}
            </tbody>
        </table>
        {{/if}}

        {{!-- Build validation (point-buy budget: SP ≤ 2×STR, weight ≤ capacity, per-area spaces). --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.BuildHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.TotalCostTip'}}">
                <label>{{CPLocal "Vehicle.TotalCostLabel"}}</label><input type="number" class="not-editable" value="{{system.buildCost}}" readonly/></div>
            <div class="field" title="{{CPLocal 'Vehicle.WeightCapTip'}}">
                <label>{{CPLocal "Vehicle.WeightCapLabel"}}</label><input type="text" class="not-editable" value="{{system.totalWeight}} / {{system.lift}} kg" readonly/></div>
        </div>
        {{#if acpaBuildValid}}
        <p class="cp-acpa-build-valid">{{CPLocal "Vehicle.LegalBuild"}}</p>
        {{else}}
        <div class="cp-acpa-build-issues">
            <p class="cp-acpa-build-issues-header">{{CPLocal "Vehicle.BuildIssuesHeader"}}</p>
            <ul style="margin:0; padding-left:18px; font-size:0.82em;">
                {{#each acpaBuildIssues as |issue|}}<li>{{issue}}</li>{{/each}}
            </ul>
        </div>
        {{/if}}
        {{/if}}

        {{!-- Notes --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.NotesHeader"}}</h2>
        <textarea name="system.notes" rows="4" style="width:100%;">{{system.notes}}</textarea>

        <p style="opacity:0.6; font-size:0.8em; margin-top:6px;">{{CPLocal "Vehicle.AcpaFootnote"}}</p>
    </div>
</div>
