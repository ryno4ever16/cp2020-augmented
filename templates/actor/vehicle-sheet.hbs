{{!-- V2 sheet: the outer <form> element is provided by ApplicationV2 (tag:"form" in DEFAULT_OPTIONS).
     Template content starts directly with the header.
     V2 requires each PART to render a SINGLE root element, so wrap everything in one div. --}}
<div class="cp-vehicle-sheet-root flexcol">
    {{!-- Header --}}
    <header class="cyberheader">
        <div class="flexrow">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
            <div class="flexcol" style="flex:1; margin-left:8px;">
                <h1 class="title"><input type="text" class="field-value" name="name" value="{{actor.name}}" autocomplete="off" data-lpignore="true" data-1p-ignore data-bwignore/></h1>
                <div class="fieldrow">
                    <div class="field">
                        <label>{{CPLocal "Vehicle.TypeLabel"}}</label>
                        <select name="system.vehicleType">
                            {{#each vehicleTypes}}<option value="{{this}}" {{#if (equals ../system.vehicleType this)}}selected{{/if}}>{{CPLocal this}}</option>{{/each}}
                        </select>
                    </div>
                    <div class="field" title="{{CPLocal 'Vehicle.AcpaPoweredArmorTip'}}">
                        <label>{{CPLocal "Vehicle.AcpaPoweredArmorLabel"}}</label>
                        <input type="checkbox" name="system.isACPA" {{#if system.isACPA}}checked{{/if}}/>
                    </div>
                    <div class="field" title="{{CPLocal 'Vehicle.RulesetTip'}}">
                        <label>{{CPLocal "Vehicle.RulesetLabel"}}</label>
                        <span class="cp-ruleset-badge">{{ruleSystemLabel}}</span>
                    </div>
                    {{#if controlEnabled}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="controlRoll" title="{{CPLocal 'Vehicle.ControlRollTipVehicle'}}">{{CPLocal "Vehicle.ControlRollBtn"}}</button>
                    </div>
                    {{/if}}
                    {{#if damageEnabled}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="vehicleDamage" title="{{CPLocal 'Vehicle.DamageTipVehicle'}}">{{CPLocal "Vehicle.DamageBtn"}}</button>
                    </div>
                    {{/if}}
                    {{#if mmOn}}{{#if system.isACPA}}
                    <div class="field cp-header-action">
                        <button type="button" data-action="acpaMelee" title="{{CPLocal 'Vehicle.MeleeTip'}}">{{CPLocal "Vehicle.MeleeBtn"}}</button>
                    </div>
                    {{/if}}{{/if}}
                </div>
            </div>
        </div>
    </header>

    <div class="sheet-body flexcol" style="overflow-y:auto;">

        {{!-- Armor & Structure --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.ArmorStructureHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.SpFrontTip'}}">
                <label>{{#if isMM}}{{CPLocal "Vehicle.SpFrontLabelMM"}}{{else}}{{CPLocal "Vehicle.SpFrontLabel"}}{{/if}}</label>
                <input type="number" name="system.sp.front" value="{{system.sp.front}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.AvFrontTip'}}">
                <label>{{CPLocal "Vehicle.AvFrontLabel"}}</label>
                <input type="number" class="not-editable" value="{{system.armorValue.front}}" readonly/>
            </div>
        </div>
        {{#if isMM}}
        <div class="field-list" title="{{CPLocal 'Vehicle.FacingSpTip'}}">
            <div class="field"><label>{{CPLocal "Vehicle.SideSpLabel"}}</label><input type="number" name="system.sp.side" value="{{system.sp.side}}"/></div>
            <div class="field"><label>{{CPLocal "Vehicle.AvSideLabel"}}</label><input type="number" class="not-editable" value="{{system.armorValue.side}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.RearSpLabel"}}</label><input type="number" name="system.sp.rear" value="{{system.sp.rear}}"/></div>
            <div class="field"><label>{{CPLocal "Vehicle.AvRearLabel"}}</label><input type="number" class="not-editable" value="{{system.armorValue.rear}}" readonly/></div>
        </div>
        <div class="field-list">
            <div class="field"><label>{{CPLocal "Vehicle.TopSpLabel"}}</label><input type="number" name="system.sp.top" value="{{system.sp.top}}"/></div>
            <div class="field"><label>{{CPLocal "Vehicle.AvTopLabel"}}</label><input type="number" class="not-editable" value="{{system.armorValue.top}}" readonly/></div>
            <div class="field"><label>{{CPLocal "Vehicle.BottomSpLabel"}}</label><input type="number" name="system.sp.bottom" value="{{system.sp.bottom}}"/></div>
            <div class="field"><label>{{CPLocal "Vehicle.AvBottomLabel"}}</label><input type="number" class="not-editable" value="{{system.armorValue.bottom}}" readonly/></div>
        </div>
        {{/if}}
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.SdpCurrentVehicleTip'}}">
                <label>{{CPLocal "Vehicle.SdpCurrentLabel"}}</label><input type="number" name="system.sdp.value" value="{{system.sdp.value}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.SdpMaxVehicleTip'}}">
                <label>{{CPLocal "Vehicle.SdpMaxLabel"}}</label><input type="number" name="system.sdp.max" value="{{system.sdp.max}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.BodyValueVehicleTip'}}">
                <label>{{CPLocal "Vehicle.BodyValueLabel"}}</label>
                <input type="number" class="not-editable" value="{{system.bodyValue}}" readonly/>
            </div>
            {{#if system.destroyed}}<div class="field"><label class="cp-vehicle-destroyed">{{CPLocal "Vehicle.Destroyed"}}</label></div>{{/if}}
        </div>
        {{#if system.isACPA}}
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.ChassisStrVehicleTip'}}"><label>{{CPLocal "Vehicle.ChassisStrLabel"}}</label><input type="number" name="system.str" value="{{system.str}}"/></div>
        </div>
        {{/if}}

        {{!-- ACPA combat status (Maximum Metal p.55-56): written by the powered-armor damage resolver
              + per-round ticks; editable here so the GM can adjust/reset (e.g. field repairs). --}}
        {{#if mmOn}}{{#if system.isACPA}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.AcpaCombatStatusHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.StrDamageTip'}}">
                <label>{{CPLocal "Vehicle.StrDamageLabel"}}</label><input type="number" name="system.strDamage" value="{{system.strDamage}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.RefDamageTip'}}">
                <label>{{CPLocal "Vehicle.RefDamageLabel"}}</label><input type="number" name="system.refDamage" value="{{system.refDamage}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.PowerHrsTip'}}">
                <label>{{CPLocal "Vehicle.PowerHrsLabel"}}</label><input type="number" name="system.powerHours" value="{{system.powerHours}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.CoolingMinTipVehicle'}}">
                <label>{{CPLocal "Vehicle.CoolingMinLabel"}}</label><input type="number" name="system.coolingTimer" value="{{system.coolingTimer}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.InterfaceOutTip'}}">
                <label>{{CPLocal "Vehicle.InterfaceOutLabel"}}</label><input type="number" name="system.interfaceOut" value="{{system.interfaceOut}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.SeizedRdsTipVehicle'}}">
                <label>{{CPLocal "Vehicle.SeizedRdsLabel"}}</label><input type="number" name="system.seizeUp" value="{{system.seizeUp}}"/></div>
        </div>
        {{/if}}{{/if}}

        {{!-- Movement --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.MovementHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.TopSpeedTip'}}">
                <label>{{CPLocal "Vehicle.TopSpeedLabel"}}</label><input type="number" name="system.topSpeed" value="{{system.topSpeed}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.SafeSpeedTip'}}">
                <label>{{CPLocal "Vehicle.SafeSpeedLabel"}}</label><input type="number" name="system.safeSpeed" value="{{system.safeSpeed}}"/>
            </div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.AccelerationTip'}}">
                <label>{{CPLocal "Vehicle.AccelerationLabel"}}</label><input type="number" name="system.acc" value="{{system.acc}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.DecelerationTip'}}">
                <label>{{CPLocal "Vehicle.DecelerationLabel"}}</label><input type="number" name="system.dec" value="{{system.dec}}"/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.ControlModTip'}}">
                <label>{{CPLocal "Vehicle.ControlModLabel"}}</label><input type="number" name="system.controlMod" value="{{system.controlMod}}"/>
            </div>
        </div>

        {{!-- Crew & Systems --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.CrewSystemsHeader"}}</h2>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.CrewSlotsTip'}}"><label>{{CPLocal "Vehicle.CrewSlotsLabel"}}</label><input type="number" name="system.crewSlots" value="{{system.crewSlots}}"/></div>
            <div class="field" title="{{CPLocal 'Vehicle.PassengerSlotsTip'}}"><label>{{CPLocal "Vehicle.PassengerSlotsLabel"}}</label><input type="number" name="system.passengerSlots" value="{{system.passengerSlots}}"/></div>
        </div>
        <div class="field-list">
            <div class="field" title="{{CPLocal 'Vehicle.VehicleLinkTip'}}">
                <label>{{CPLocal "Vehicle.VehicleLinkLabel"}}</label><input type="checkbox" name="system.vehicleLink" {{#if system.vehicleLink}}checked{{/if}}/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.DamageControlTip'}}">
                <label>{{CPLocal "Vehicle.DamageControlLabel"}}</label><input type="checkbox" name="system.damageControl" {{#if system.damageControl}}checked{{/if}}/>
            </div>
            {{#if mmOn}}
            <div class="field" title="{{CPLocal 'Vehicle.CompositeArmorTip'}}">
                <label>{{CPLocal "Vehicle.CompositeArmorLabel"}}</label><input type="checkbox" name="system.compositeArmor" {{#if system.compositeArmor}}checked{{/if}}/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.ReactiveArmorTip'}}">
                <label>{{CPLocal "Vehicle.ReactiveArmorLabel"}}</label><input type="checkbox" name="system.reactiveArmor" {{#if system.reactiveArmor}}checked{{/if}}/>
            </div>
            {{#if system.reactiveArmor}}
            <div class="field" title="{{CPLocal 'Vehicle.ReactiveWearTip'}}">
                <label>{{CPLocal "Vehicle.ReactiveWearLabel"}}</label>
                <span class="cp-reactive-wear">{{system.reactiveHits}} hit{{#unless oneReactiveHit}}s{{/unless}}{{#if reactiveWear}} (−{{reactiveWear}}){{/if}}<button type="button" data-action="reactiveReplace" title="{{CPLocal 'Vehicle.ReactiveReplaceTip'}}">{{CPLocal "Vehicle.ReactiveReplaceBtn"}}</button></span>
            </div>
            {{/if}}
            <div class="field" title="{{CPLocal 'Vehicle.SensorsRadarTip'}}">
                <label>{{CPLocal "Vehicle.SensorsRadarLabel"}}</label><input type="checkbox" name="system.sensors" {{#if system.sensors}}checked{{/if}}/>
            </div>
            <div class="field" title="{{CPLocal 'Vehicle.AntiMissileTip'}}">
                <label>{{CPLocal "Vehicle.AntiMissileGagsLabel"}}</label><input type="checkbox" name="system.antiMissile" {{#if system.antiMissile}}checked{{/if}}/>
            </div>
            {{/if}}
            <div class="field" title="{{CPLocal 'Vehicle.FireControlTipVehicle'}}">
                <label>{{CPLocal "Vehicle.FireControl"}}</label><input type="number" name="system.fireControl" value="{{system.fireControl}}"/>
            </div>
        </div>

        {{#if mmOn}}{{> "modules/cp2020-augmented/templates/actor/parts/countermeasures.hbs"}}{{/if}}

        {{!-- Weapon Mounts = embedded vehicleWeapon Items (drag from the Vehicle Weapons (MM) compendium).
              The MM weapon system (Penetration/arc/missiles/bursts) is Maximum Metal — hidden when MM is off. --}}
        {{#if mmOn}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.WeaponsHeader"}}</h2>
        <div class="cp-weapons">
            {{#each weapons as |weapon|}}
            <div class="field-list cp-weapon-row">
                <img class="cp-weapon-img" src="{{weapon.img}}" width="24" height="24"/>
                <span class="cp-weapon-name" title="{{weapon.system.weaponClass}} · {{weapon.system.mountType}} mount"><b>{{weapon.name}}</b>{{#if weapon.system.activeShell}} <span style="opacity:0.7;font-size:0.85em;">▸ {{weapon.system.activeShell}}</span>{{/if}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponPenTip'}}">Pen {{weapon.system.penetration}}{{#if weapon.system.ap}} AP{{/if}}{{#if weapon.system.heat}} HEAT{{/if}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponRofTip'}}">ROF {{weapon.system.rof}}</span>
                <span class="cp-weapon-stat" title="{{CPLocal 'Vehicle.WeaponArcTip'}}">{{weapon.system.arc}}</span>
                {{#if @root.damageEnabled}}<button type="button" data-action="weaponFire" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponFireTip'}}">🎯</button>{{/if}}
                <button type="button" data-action="weaponEdit" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponEditTip'}}">✎</button>
                <button type="button" data-action="weaponDelete" data-weapon-id="{{weapon.id}}" title="{{CPLocal 'Vehicle.WeaponDeleteTip'}}">✕</button>
            </div>
            {{/each}}
            <button type="button" data-action="weaponAdd" title="{{CPLocal 'Vehicle.WeaponAddTip'}}">{{CPLocal "Vehicle.WeaponAddBtn"}}</button>
            <p style="opacity:0.6; font-size:0.78em; margin-top:2px;">{{CPLocal "Vehicle.WeaponsDragNote"}}</p>
        </div>
        {{/if}}

        {{!-- Notes --}}
        <h2 class="cyber-section-header">{{CPLocal "Vehicle.NotesHeader"}}</h2>
        <textarea name="system.notes" rows="4" style="width:100%;">{{system.notes}}</textarea>

        <p style="opacity:0.6; font-size:0.8em; margin-top:6px;">{{CPLocal "Vehicle.VehicleFootnote"}}</p>
    </div>
</div>
