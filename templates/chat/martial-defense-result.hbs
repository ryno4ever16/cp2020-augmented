{{!--
  Offered-defense RESULT (the defender rolled). Rendered from _rollOfferedDefense() in
  module/martial/martial.js; the opposed roll rides the message's rolls[]. The GM compares this
  total against the attack roll already on the table and adjudicates with the two buttons —
  [lands] applies the status via the relay path, [evaded] posts the miss and writes nothing.
--}}
<div class="cyberpunk save-prompt martial-defense-result">
  <h3>{{title}}</h3>
  <div class="save-info">
    <span>{{{breakdown}}}</span>
    {{#if dodgeClause}}<br><span>{{{dodgeClause}}}</span>{{/if}}
  </div>
  <div class="save-buttons">
    <button class="cp-martial-defense-lands" data-action="{{action}}"
            data-attacker-actor-id="{{attackerActorId}}" data-target-actor-id="{{targetActorId}}"
            data-target-token-id="{{targetTokenId}}">{{CPLocal "MartialDefenseLandsBtn"}}</button>
    <button class="cp-martial-defense-evaded" data-action="{{action}}"
            data-attacker-actor-id="{{attackerActorId}}" data-target-actor-id="{{targetActorId}}"
            data-target-token-id="{{targetTokenId}}">{{CPLocal "MartialDefenseEvadedBtn"}}</button>
  </div>
</div>
