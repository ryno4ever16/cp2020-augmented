{{!--
  Martial-arts attack result. Posted by rollMartialAttack (module/martial/martial.js) via
  ChatMessage.create with the rolls attached for Dice So Nice. The rendered roll HTML is
  triple-stashed; the title is pre-localized in JS (CYBERPUNK.MartialTitle). CPLocal for chrome;
  Location/Damage are shared system keys, MartialAttackLabel/MartialNoDamageNote are module-owned.
--}}
<div class="cyberpunk cp2020ae-martial-attack">
  <header class="cp2020ae-martial-card-header">
    {{#if img}}<img class="cp2020ae-martial-card-img" src="{{img}}" alt="{{actorName}}">{{/if}}
    <h3>{{title}}</h3>
  </header>

  <div class="cp2020ae-martial-roll-line">
    <span class="cp2020ae-martial-roll-label">{{CPLocal "MartialAttackLabel"}}</span>
    {{{attackRender}}}
  </div>

  {{#if hasDamage}}
    <div class="cp2020ae-martial-roll-line">
      <span class="cp2020ae-martial-roll-label">{{CPLocal "Location"}}</span>
      <span class="cp2020ae-martial-area">{{areaHit}}</span>
    </div>
    <div class="cp2020ae-martial-roll-line">
      <span class="cp2020ae-martial-roll-label">{{CPLocal "Damage"}}</span>
      {{{damageRender}}}
    </div>
  {{/if}}

  {{#if contested}}
    <div class="cp2020ae-martial-roll-line">
      <span class="cp2020ae-martial-roll-label">{{CPLocal "MartialDefenseLabel"}}</span>
      {{{contested.defenseRender}}}
    </div>
    <p class="cp2020ae-martial-defense-detail">{{CPLocal "MartialDefenseDetail" name=contested.defenderName skill=contested.skillName val=contested.skillVal ref=contested.ref}}{{#if contested.dodgeBonus}} {{CPLocal "MartialDodgeBonus" bonus=contested.dodgeBonus}}{{/if}}</p>
    <p class="cp2020ae-martial-verdict">
      {{#if contested.parried}}{{{CPLocal "MartialParried" name=contested.defenderName}}}{{else if contested.hits}}{{{CPLocal "MartialHits" name=contested.defenderName}}}{{else}}{{{CPLocal "MartialMisses" name=contested.defenderName}}}{{/if}}
    </p>
  {{else}}
    {{#unless hasDamage}}<p class="cp2020ae-martial-note">{{CPLocal "MartialNoDamageNote"}}</p>{{/unless}}
  {{/if}}
</div>
