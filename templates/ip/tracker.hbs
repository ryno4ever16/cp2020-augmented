<div class="cp-ip-tracker-window flexcol" style="height:100%;">
    <div class="flexrow" style="gap:8px; align-items:center; padding:4px 0;">
        <button type="button" data-action="ipManual" title="{{localize "CYBERPUNK.IpManualAddTip"}}">＋ {{localize "CYBERPUNK.IpManualAdd"}}</button>
        <span class="flex-pad" style="flex:1;"></span>
        {{#unless (equals throttle "off")}}<button type="button" data-action="ipReset" title="{{localize "CYBERPUNK.IpThrottleResetTip"}}">↻ {{localize "CYBERPUNK.IpThrottleResetBtn"}}</button>{{/unless}}
        <button type="button" data-action="ipApply" title="{{localize "CYBERPUNK.IpApplyTip"}}"><b>{{localize "CYBERPUNK.IpApply"}}</b></button>
    </div>

    {{!-- RAW auto-tracking is off → skill rolls don't queue here. Explain so it isn't mistaken for a bug. --}}
    {{#if simple}}
    <p class="cp-ip-rawoff-note">{{localize "CYBERPUNK.IpRawOffNote"}}</p>
    {{/if}}

    {{!-- Queue of skill rolls awaiting an IP decision --}}
    <h2 class="cyber-section-header">{{localize "CYBERPUNK.IpQueue"}} {{#if rowCount}}({{rowCount}}){{/if}}</h2>
    <div class="flexcol" style="overflow-y:auto; min-height:60px; max-height:45%;">
        {{#if rowCount}}
        {{#each rows as |row|}}
        <div class="flexrow cp-ip-row" data-row-id="{{row.id}}" style="align-items:center; gap:6px; padding:2px 4px;">
            <span style="flex:1;" title="{{CPLocal 'IpRolledTip' total=row.total}}">{{row.actorName}} · <b>{{row.skillName}}</b> <span style="opacity:0.6;">({{row.total}})</span></span>
            {{#if ../auto}}
            <label title="{{localize "CYBERPUNK.IpSuccessTip"}}"><input type="checkbox" class="cp-ip-success" {{#if row.success}}checked{{/if}}/> {{localize "CYBERPUNK.IpSuccess"}}</label>
            <input type="number" class="cp-ip-amount" value="{{row.ip}}" min="0" style="width:46px;" title="{{localize "CYBERPUNK.IpBonus"}}"/>
            {{else}}
            <input type="number" class="cp-ip-amount" value="{{row.ip}}" min="0" max="9" style="width:46px;" title="{{localize "CYBERPUNK.IpAmount"}}"/>
            {{/if}}
            <button type="button" data-action="ipAward" title="{{localize "CYBERPUNK.IpAwardTip"}}">✓</button>
            <button type="button" data-action="ipSkip" title="{{localize "CYBERPUNK.IpSkipTip"}}">✕</button>
        </div>
        {{/each}}
        {{else}}
        <p style="opacity:0.6; padding:6px;">{{localize "CYBERPUNK.IpQueueEmpty"}}</p>
        {{/if}}
    </div>

    {{!-- GM balances: each actor's pool + every skill that carries IP. Pool + banked are GM-editable
         (type an absolute value to add or remove); pending is shown read-only as a +N badge. --}}
    <h2 class="cyber-section-header">{{localize "CYBERPUNK.IpBalances"}}{{#if pendingTotal}} — {{localize "CYBERPUNK.IpPending"}} {{pendingTotal}}{{/if}}</h2>
    <div class="cp-ip-balances flexcol" style="overflow-y:auto; min-height:40px; flex:1;">
        {{#if hasBalances}}
        {{#each balances as |b|}}
        <div class="cp-ip-bal-actor flexrow" style="align-items:center; gap:6px; padding:3px 4px 1px;">
            <span class="cp-ip-bal-name" style="flex:1;"><b>{{b.actorName}}</b></span>
            <label title="{{localize "CYBERPUNK.IpPoolHint"}}">{{localize "CYBERPUNK.IpPool"}}
                <input type="number" class="cp-ip-pool" data-actor-id="{{b.actorId}}" value="{{b.pool}}" min="0" style="width:54px;"/>
            </label>
        </div>
        {{#each b.skills as |s|}}
        <div class="cp-ip-bal-skill flexrow" data-actor-id="{{b.actorId}}" data-skill-id="{{s.skillId}}" style="align-items:center; gap:6px; padding:1px 4px 1px 14px;">
            <span style="flex:1;">{{s.skillName}}</span>
            {{#if s.pending}}<span class="cp-ip-pend-badge" title="{{localize "CYBERPUNK.IpPendingPip"}}">+{{s.pending}}</span>{{/if}}
            <label title="{{localize "CYBERPUNK.IpBankHint"}}">{{localize "CYBERPUNK.IpBanked"}}
                <input type="number" class="cp-ip-bank" value="{{s.bank}}" min="0" style="width:54px;"/>
            </label>
        </div>
        {{/each}}
        {{/each}}
        {{else}}
        <p style="opacity:0.6; padding:6px;">{{localize "CYBERPUNK.IpBalancesEmpty"}}</p>
        {{/if}}
    </div>

    <p style="opacity:0.55; font-size:0.74em; margin:4px 0 0;">{{localize "CYBERPUNK.IpTrackerFooter"}}</p>
</div>
